// examples/2.if-else/main.cm
@attribute("c-no-print")
import "libc/stdio.h"


func main() -> IntInt {
    printf("if-else example\n")

    var a: Int32
    var b: Int32

    printf("enter a: ")
    scanf("%d", &a)
    printf("enter b: ")
    scanf("%d", &b)

    if a > b {
        printf("a > b\n")
    } else if a < b {
        printf("a < b\n")
    } else {
        printf("a == b\n")
    }

    return 0
}

