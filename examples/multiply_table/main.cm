
//!attribute('no-c-include')
include "libc.hm"


func mtab (n : Nat32) -> Unit {
  var m : Nat32
  m := 1
  while m < 10 {
    let nm = n * m
    printf("%d * %d = %d\n", n, m, nm)
    m := m + 1
  }
}


func main () -> Int {
  let n = 2
  printf("multiply table for %d\n", n)
  mtab(n)
  return 0
}

