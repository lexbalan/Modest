// examples/3.multiply_table/main.cm
@attribute("c-no-print")
import "libc/stdio.h"


func mtab(n: Int) -> Unit {
    //var m : Nat32
    //m := 1
    var m: Int32 := 1
    while m < 10 {
        let nm = n * m
        printf("%d * %d = %d\n", n, m, nm)
        m := m + 1
    }
}


func main() -> Int {
    let n = 2 * 2
    printf("multiply table for %d\n", n to Int32)
    mtab(n)
    return 0
}

