



import "libc/stdio.h"


func mtab (n : Int32) -> Unit {
    var m : Int32 := 1
    while m < 10 {
        let nm = n * m
        printf("%d * %d = %d\n", n, m, nm)
        m := m + 1
    }
}


func main () -> Int32 {
    let n = 2
    printf("multiply table for %d\n", n)
    mtab(n)
    return 0
}

