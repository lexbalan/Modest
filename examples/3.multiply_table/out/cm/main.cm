// examples/3.multiply_table/src/main.cm

import "libc/stdio.h"


func mtab(n: Nat32) -> Unit {
    var m: Nat32 = 1
    // or
    //var m = 1   // by default integer var get system int type (-mint option)
    while m < 10 {
        let nm = n * m
        printf("%d * %d = %d\n", n, m, nm)
        m = m + 1
    }
}


func main() -> Int {
    let n = 2 * 2
    printf("multiply table for %d\n", n to Int32)
    mtab(n)
    return 0
}

