// lib/lightfood/delay.cm

import "libc/libc"   // for clock()


func delay_us(us: Nat64) {
    let start_time = clock()
    while (clock() < start_time + us) {
        // just waiting
    }
}


func delay(us: Nat64) {
    delay_us(us)
}


func delay_ms(ms: Nat64) {
    delay_us(ms * 1000)
}


func delay_s(s: Nat64) {
    delay_ms(s * 1000)
}


