// test/11.unicode/main.cm
import "libc/stdio.h"
import "misc/utf.h"




const ratSymbolUTF8 = [0xF0, 0x9F, 0x90, 0x80]
const ratSymbolUTF16 = [0xD83D, 0xDC00]
const ratSymbolUTF32 = 0x0001F400


var arr_utf8 : [8]Char8 := "Hi!\n"
var arr_utf16 : [8]Char16 := "Hello!\n"
var arr_utf32 : [8]Char32 := "Hello!\n"



const genericStringConst = "S-t-r-i-n-g-Ω 🐀🎉🦄\n"
const string8Const = genericStringConst to *[]Char8
const string16Const = genericStringConst to *[]Char16
const string32Const = genericStringConst to *[]Char32


func main () -> Int {
    // indexing of GenericString returns #i symbol code
    // the symbols have GenericInteger type
    //    let omegaCharCode = "Hello Ω!\n"[6]
    //    let ratCharCode = "Hello 🐀!\n"[6]

    // you can assign omegaCharCode (937) to Nat32,
    // but you can't assign ratCharCode (128000) to Nat16 (!)
    //    var omegaCode : Nat16 := omegaCharCode to Nat16
    //    var ratCode : Nat32 := ratCharCode to Nat32

    //    printf("omegaCode = %d\n", omegaCode)
    //    printf("ratCode = %d\n", ratCode)


    var i : Int32 := 0
    while 1 {
        let c = string16Const[i]
        if c == 0 {
            break
        }

        printf("[%d]U16: 0x%x\n", i, c to Nat32)

        i := i + 1
    }


    var str8 : *[]Char8 := string8Const
    var str16 : *[]Char16 := string16Const
    var str32 : *[]Char32 := string32Const

    utf8_puts(str8)
    utf8_puts("\n")

    utf16_puts(str16)
    utf8_puts("\n")

    utf32_puts(str32)
    utf8_puts("\n")

    return 0
}

