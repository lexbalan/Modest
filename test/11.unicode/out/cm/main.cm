// test/11.unicode/main.cm
import "libc/stdio.h"
import "misc/utf.h"




const ratSymbolUTF8 = [0xF0, 0x9F, 0x90, 0x80]
const ratSymbolUTF16 = [0xD83D, 0xDC00]
const ratSymbolUTF32 = 0x0001F400


var arr_utf8 : [8]Char8 := ["72"[0], "105"[0], "33"[0], "\xa"[0]]
var arr_utf16 : [8]Char16 := ["72"[0], "101"[0], "108"[0], "108"[0], "111"[0], "33"[0], "\xa"[0]]
var arr_utf32 : [8]Char32 := ["72"[0], "101"[0], "108"[0], "108"[0], "111"[0], "33"[0], "\xa"[0]]



const genericStringConst = "S-t-r-i-n-g"
const string8Const = ["83"[0], "45"[0], "116"[0], "45"[0], "114"[0], "45"[0], "105"[0], "45"[0], "110"[0], "45"[0], "103"[0], "\x0"[0]]
const string16Const = ["83"[0], "45"[0], "116"[0], "45"[0], "114"[0], "45"[0], "105"[0], "45"[0], "110"[0], "45"[0], "103"[0], "\x0"[0]]
const string32Const = ["83"[0], "45"[0], "116"[0], "45"[0], "114"[0], "45"[0], "105"[0], "45"[0], "110"[0], "45"[0], "103"[0], "\x0"[0]]


func main () -> Int {
    // indexing of GenericString returns #i symbol code
    // the symbols have GenericInteger type
    //    let omegaCharCode = "Hello Ω!\n"[6]
    //    let ratCharCode = "Hello 🐀!\n"[6]

    // you can assign omegaCharCode (937) to Nat32,
    // but you can't assign ratCharCode (128000) to Nat16 (!)
    //    var omegaCode : Nat16 := omegaCharCode to Nat16
    //    var ratCode : Nat32 := ratCharCode to Nat32

    //    printf("omegaCode = %d\n", omegaCode)
    //    printf("ratCode = %d\n", ratCode)


    utf16_puts(["72"[0], "101"[0], "108"[0], "108"[0], "111"[0], "32"[0], "937"[0], "33"[0], "\xa"[0], "\x0"[0]])
    utf32_puts(["72"[0], "101"[0], "108"[0], "108"[0], "111"[0], "32"[0], "937"[0], "33"[0], "\xa"[0], "\x0"[0]])

    utf32_puts(["72"[0], "101"[0], "108"[0], "108"[0], "111"[0], "32"[0], "128000"[0], "33"[0], "\xa"[0], "\x0"[0]])


    var str8 : *[]Char8 := string8Const
    var str16 : *[]Char16 := string16Const
    var str32 : *[]Char32 := string32Const

    utf8_puts(str8)
    utf8_puts(["\xa"[0], "\x0"[0]])

    utf16_puts(str16)
    utf8_puts(["\xa"[0], "\x0"[0]])

    utf32_puts(str32)
    utf8_puts(["\xa"[0], "\x0"[0]])

    return 0
}

