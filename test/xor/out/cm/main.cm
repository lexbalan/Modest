// test/sha256/main.cm
import "libc/stdio.h"
import "libc/libc.h"


func xor_encrypter (buf : *[]Nat8, buflen : Nat32, key : *[]Nat8, keylen : Nat32) -> Unit {
    var i : Nat32 := 0
    var j : Nat32 := 0
    while i < buflen {
        buf[i] := buf[i] xor key[j]

        i := i + 1

        if j < keylen - 1 {
            j := j + 1
        } else {
            j := 0
        }
    }
}

//xor_encrypt = xor_encrypter
//xor_decrypt = xor_encrypter

const msg_length = 12
const key_length = 3

var test_msg : [msg_length + 1]Char8 := ["H"[0], "e"[0], "l"[0], "l"[0], "o"[0], " "[0], "W"[0], "o"[0], "r"[0], "l"[0], "d"[0], "!"[0]]
var test_key : [key_length + 1]Char8 := ["a"[0], "b"[0], "c"[0]]


func print_bytes (buf : *[]Nat8, len : Nat32) -> Unit {
    var i : Nat32 := 0
    while i < len {
        printf(["0"[0], "x"[0], "%"[0], "0"[0], "2"[0], "X"[0], " "[0], "\x0"[0]], buf[i])
        i := i + 1
    }
    printf(["\xa"[0], "\x0"[0]])
}


func main () -> Int {
    printf(["t"[0], "e"[0], "s"[0], "t"[0], " "[0], "x"[0], "o"[0], "r"[0], " "[0], "e"[0], "n"[0], "c"[0], "r"[0], "y"[0], "p"[0], "t"[0], "i"[0], "n"[0], "g"[0], "\xa"[0], "\x0"[0]])

    let tmsg = &test_msg to *[]Nat8
    let tkey = &test_key to *[]Nat8

    printf(["b"[0], "e"[0], "f"[0], "o"[0], "r"[0], "e"[0], " "[0], "e"[0], "n"[0], "c"[0], "r"[0], "y"[0], "p"[0], "t"[0], " "[0], "t"[0], "e"[0], "s"[0], "t"[0], "_"[0], "m"[0], "s"[0], "g"[0], ":"[0], " "[0], "\xa"[0], "\x0"[0]])
    print_bytes(tmsg, msg_length)

    // encrypt test data
    xor_encrypter(tmsg, msg_length, tkey, key_length)

    printf(["a"[0], "f"[0], "t"[0], "e"[0], "r"[0], " "[0], "e"[0], "n"[0], "c"[0], "r"[0], "y"[0], "p"[0], "t"[0], " "[0], "t"[0], "e"[0], "s"[0], "t"[0], "_"[0], "m"[0], "s"[0], "g"[0], ":"[0], " "[0], "\xa"[0], "\x0"[0]])
    print_bytes(tmsg, msg_length)

    // decrypt test data
    xor_encrypter(tmsg, msg_length, tkey, key_length)

    printf(["a"[0], "f"[0], "t"[0], "e"[0], "r"[0], " "[0], "d"[0], "e"[0], "c"[0], "r"[0], "y"[0], "p"[0], "t"[0], " "[0], "t"[0], "e"[0], "s"[0], "t"[0], "_"[0], "m"[0], "s"[0], "g"[0], ":"[0], " "[0], "\xa"[0], "\x0"[0]])
    print_bytes(tmsg, msg_length)

    return 0
}

