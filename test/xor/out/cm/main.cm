// test/sha256/main.cm
import "libc/stdio.h"
import "libc/libc.h"


func xor_encrypter (buf : *[]Nat8, buflen : Nat32, key : *[]Nat8, keylen : Nat32) -> Unit {
    var i : Nat32 := 0
    var j : Nat32 := 0
    while i < buflen {
        buf[i] := buf[i] xor key[j]

        i := i + 1

        if j < keylen - 1 {
            j := j + 1
        } else {
            j := 0
        }
    }
}

//xor_encrypt = xor_encrypter
//xor_decrypt = xor_encrypter

const msg_length = 12
const key_length = 3

var test_msg : [msg_length + 1]Char8 := ["72"[0], "101"[0], "108"[0], "108"[0], "111"[0], "32"[0], "87"[0], "111"[0], "114"[0], "108"[0], "100"[0], "33"[0]]
var test_key : [key_length + 1]Char8 := ["97"[0], "98"[0], "99"[0]]


func print_bytes (buf : *[]Nat8, len : Nat32) -> Unit {
    var i : Nat32 := 0
    while i < len {
        printf(["48"[0], "120"[0], "37"[0], "48"[0], "50"[0], "88"[0], "32"[0], "\x0"[0]], buf[i])
        i := i + 1
    }
    printf(["\xa"[0], "\x0"[0]])
}


func main () -> Int {
    printf(["116"[0], "101"[0], "115"[0], "116"[0], "32"[0], "120"[0], "111"[0], "114"[0], "32"[0], "101"[0], "110"[0], "99"[0], "114"[0], "121"[0], "112"[0], "116"[0], "105"[0], "110"[0], "103"[0], "\xa"[0], "\x0"[0]])

    printf(["98"[0], "101"[0], "102"[0], "111"[0], "114"[0], "101"[0], "32"[0], "116"[0], "101"[0], "115"[0], "116"[0], "95"[0], "109"[0], "115"[0], "103"[0], "58"[0], "32"[0], "\xa"[0], "\x0"[0]])
    print_bytes(&test_msg to *[]Nat8, msg_length)

    xor_encrypter(&test_msg to *[]Nat8, msg_length, &test_key to *[]Nat8, key_length)

    printf(["97"[0], "102"[0], "116"[0], "101"[0], "114"[0], "32"[0], "116"[0], "101"[0], "115"[0], "116"[0], "95"[0], "109"[0], "115"[0], "103"[0], "58"[0], "32"[0], "\xa"[0], "\x0"[0]])
    print_bytes(&test_msg to *[]Nat8, msg_length)

    xor_encrypter(&test_msg to *[]Nat8, msg_length, &test_key to *[]Nat8, key_length)

    printf(["97"[0], "102"[0], "116"[0], "101"[0], "114"[0], "50"[0], "32"[0], "116"[0], "101"[0], "115"[0], "116"[0], "95"[0], "109"[0], "115"[0], "103"[0], "58"[0], "32"[0], "\xa"[0], "\x0"[0]])
    print_bytes(&test_msg to *[]Nat8, msg_length)

    return 0
}

