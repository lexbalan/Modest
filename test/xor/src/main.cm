// test/sha256/main.cm

@attribute("c-no-print")
import "libc/stdio.hm"

@attribute("c-no-print")
import "libc/libc.hm"


func xor_encrypter(buf: *[]Nat8, buflen: Nat32, key: *[]Nat8, keylen: Nat32) -> Unit {
    var i := 0 to Nat32
    var j := 0 to Nat32
    while i < buflen {
        buf[i] := buf[i] xor key[j]

        i := i + 1

        if (j < (keylen - 1)) {
            j := j + 1
        } else {
            j := 0
        }
    }
}

//xor_encrypt = xor_encrypter
//xor_decrypt = xor_encrypter

const msg_length = 12
const key_length = 3

var test_msg: [msg_length + 1]Char8 := "Hello World!"
var test_key: [key_length + 1]Char8 := "abc"


func print_bytes(buf: *[]Nat8, len: Nat32) -> Unit {
    var i := 0 to Nat32
    while i < len {
        printf("0x%02X ", buf[i])
        i := i + 1
    }
    printf("\n")
}


func main() -> Int {
    printf("test xor encrypting\n")

    let tmsg = &test_msg to *[]Nat8
    let tkey = &test_key to *[]Nat8

    printf("before encrypt test_msg: \n")
    print_bytes(tmsg, msg_length)

    // encrypt test data
    xor_encrypter(tmsg, msg_length, tkey, key_length)

    printf("after encrypt test_msg: \n")
    print_bytes(tmsg, msg_length)

    // decrypt test data
    xor_encrypter(tmsg, msg_length, tkey, key_length)

    printf("after decrypt test_msg: \n")
    print_bytes(tmsg, msg_length)

    return 0
}

