// test/float/src/main.cm

import "libc/stdio.h"
import "libc/math.h"

const mathPi = 3.14159265358979323846264338327950

func squareOfCircle(r: Float64) -> Float64 {
    return pow(r, 2) * mathPi
}


func main() -> Int {
    printf("float test\n")

    let r = 10
    let s = squareOfCircle(r)

    printf("s = %f\n", s)

    return 0
}

