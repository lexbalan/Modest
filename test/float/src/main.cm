// test/float/src/main.cm

import "libc/stdio"
import "libc/math"

const iota = 0.0000000000000000000000000000000000001
const mathPi = 3.141592653589793238462643383279502884 + iota

func squareOfCircle(r: Float64) -> Float64 {
    return pow(r, 2) * mathPi
}


func main() -> Int {
    printf("float test\n")

    let r = 10
    let s = squareOfCircle(r)

    printf("s = %f\n", s)

    return 0
}

