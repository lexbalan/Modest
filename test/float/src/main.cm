// test/float/src/main.cm

import "libc/stdio"
import "libc/math"


let mathPi = 3.141592653589793238462643383279502884


func squareOfCircle(radius: Float64) -> Float64 {
	return pow(radius, 2) * mathPi
}


func main() -> Int {
	printf("float test\n")

	let r = 10
	let s = squareOfCircle(r)
	printf("s = %f\n", s)


	let k = Float64 1 / Float64 8
	printf("k = %f\n", k)


	return 0
}

