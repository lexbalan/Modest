// examples/1.hello_world/main.cm

@attribute("c-no-print")
import "libc/stdio.hm"


// s = sign
// p = exponent
// n = fraction
func float32 (s : Bool, p : Nat8, n : Nat32) -> Float32 {
    var bits : Nat32

    if s {
        bits := 0x80000000
    }

    bits := bits or (p to Nat32) << 23
    bits := bits or (n and 0x7FFFFF)

    // bitcast Nat32 to Float32
    var pfloat32 : *Float32
    pfloat32 := &bits to Pointer to *Float32
    return *pfloat32
}



func test2() {
    let n = 1
    let p = -128

    printf("n = %d\n", n)
    printf("p = %d\n", p)

    let f = float32(false, p, n)

    printf("t2 = %f\n", f)
}

const M_PI = 3.141592653589793238462643383279502884

func main () -> Int {
    printf("Hello World!\n")

    //test2()

    let pi = M_PI

    var f : Float32
    f := pi

    var d : Float64
    d := pi

    printf("f = %f\n", f to Float64)
    printf("d = %lf\n", d)
    printf("pi = %lf\n", pi)

    return 0

