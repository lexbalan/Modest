// examples/1.hello_world/main.cm

@attribute("c-no-print")
import "libc/stdio.hm"


type Mode enum {
	modeOff
	modeStandby
	modeOn
}



func printMode(m: Mode) {
    if m == modeOff {
        printf("modeOff\n")
    } else if m == modeStandby {
        printf("modeStandby\n")
    } else if m == modeOn {
        printf("modeOn\n")
    }
}


func main () -> Int {
    printf("enum test")

    var m: Mode
    m = modeOff

    printMode(m)
    return 0
}


