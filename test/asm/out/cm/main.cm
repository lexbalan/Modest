// test/asm/src/main.cm

import "libc/stdio"


func sum64(a: Int64, b: Int64) -> Int64 {
    var sum: Int64
    __asm("add %0, %1, %2", "=r", sum, "r", a, "r", b, "cc")
    return sum
}


func main() -> Int {
    printf("asm test")

    var a: Int64 = 10
    var b: Int64 = 20
    var sum: Int64 = sum64(a, b)
    printf("sum(%lld, %lld) = %lld\n", a, b, sum)

    return 0
}

