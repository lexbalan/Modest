
include "libc/ctypes64"
include "libc/ctypes"
include "libc/stdio"
func next(x: Int32) -> Int32 {
	if x < bufVolume - 1 {
		return x + 1
	}
	return 0
}
export let bufVolume = 4

export type Queue record {
	data: [bufVolume]Byte
	p: Int32
	g: Int32
	size: Nat32
}
export func init(self: *Queue) -> Unit {
	self.data = []  // right size = 4
	self.size = 0
	self.p = 0
	self.g = 0
}
export func getSize(self: *Queue) -> Nat32 {
	return self.size
}
export func isEmpty(self: *Queue) -> Bool {
	return self.size == 0
}
export func isFull(self: *Queue) -> Bool {
	return self.size == bufVolume
}
export func put(self: *Queue, b: Byte) -> Bool {
	if isFull(self) {
		return false
	}

	self.data[self.p] = b
	self.p = next(self.p)
	self.size = self.size + 1

	return true
}
export func get(q: *Queue) -> Byte {
	if isEmpty(q) {
		return 0
	}

	let x = q.data[q.g]
	q.g = next(q.g)
	q.size = q.size - 1
	return x
}

