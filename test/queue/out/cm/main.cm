
include "libc/ctypes64"
include "libc/ctypes"
include "libc/math"
include "libc/stdio"
import "queue"
var q0: Queue
var ii: Int32
func padd(n: Int) -> Unit {
	var i: Int32 = 0
	while i < n {
		if queue.isFull(&q0) {
			printf("queue is full\n")
			break
		}

		printf("queue.put(%d)\n", ii)
		queue.put(&q0, Byte ii)
		i = i + 1
		ii = ii + 1
	}
}
func fetch(n: Int) -> Unit {
	var i: Int32 = 0
	while i < n {
		if queue.isEmpty(&q0) {
			printf("queue is empty\n")
			break
		}

		let x = queue.get(&q0)
		printf("queue.get = %d\n", Int x)
		i = i + 1
	}
}
export func main() -> Int {
	queue.init(&q0)

	padd(3)
	fetch(7)
	padd(12)
	fetch(7)
	padd(22)
	fetch(7)

	return 0
}

