
include "console"
include "inttypes"
import "queue"
var q0: Queue
func padd(n: Int) -> Unit {
	var i: Int32 = 0
	while i < n {
		if queue.isFull(&q0) {
			printf("queue is full\n")
			break
		}

		printf("queue.put(%d)\n", i)
		queue.put(&q0, Byte i)
		i = i + 1
	}
}
func fetch(n: Int) -> Unit {
	var i: Int32 = 0
	while i < n {
		if queue.isEmpty(&q0) {
			printf("queue is empty\n")
			break
		}

		let x = queue.get(&q0)
		printf("queue.get = %d\n", Int x)
		i = i + 1
	}
}
func init() -> Unit {
	printf("init!\n")
}
export func main() -> Int {
	init()

	queue.init(&q0)

	padd(3)

	fetch(7)

	padd(12)

	fetch(7)

	padd(22)

	fetch(7)

	return 0
}

