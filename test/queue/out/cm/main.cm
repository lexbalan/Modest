
include "console"
include "inttypes"
import "queue"
var q0: Queue
func fetch(n: Int) -> Unit {
	var i: Int32 = 0
	while i < 7 {
		if queue.isEmpty(&q0) {
			printf("queue is empty\n")
			break
		}

		let x = queue.get(&q0)
		printf("x = %d\n", Int x)
		i = i + 1
	}
}
func init() -> Unit {
	printf("init!\n")
}
export func main() -> Int {
	init()

	queue.put(&q0, 10)
	queue.put(&q0, 20)
	queue.put(&q0, 30)
	queue.put(&q0, 40)
	queue.put(&q0, 50)

	fetch(7)

	queue.put(&q0, 40)
	queue.put(&q0, 50)
	queue.put(&q0, 60)
	queue.put(&q0, 70)
	queue.put(&q0, 80)

	fetch(7)

	queue.put(&q0, 11)
	queue.put(&q0, 12)
	queue.put(&q0, 13)
	queue.put(&q0, 14)
	queue.put(&q0, 15)

	fetch(7)

	return 0
}

