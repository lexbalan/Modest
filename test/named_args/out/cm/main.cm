// test/named_args/src/main.cm

import "libc/stdio"


func named_args_test(a: Int32, b: Int32, c: Int32) -> Int32 {
	return (a - b) * c
}


func main() -> Int {
	printf("test named_args\n")

	let a = 25
	let b = 15
	let c = 3

	let x = named_args_test(a = a, b = b, c = c)

	if x == (a - b) * c {
		printf("test passed\n")
	} else {
		printf("test failed\n")
	}

	return 0
}

