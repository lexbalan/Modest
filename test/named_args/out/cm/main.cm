// test/named_args/src/main.cm

import "libc/stdio"


func print_name_age(name: *Str8, age: Nat32, x: Nat32) -> Unit {
	printf("name = %s\n", name)
	printf("age = %u\n", age)
	printf("x = %u\n", x)
}

func main() -> Int {
	printf("test named_args\n")

	print_name_age(name = "Alex", age = 34, 12)

	return 0
}

