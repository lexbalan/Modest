// test/22.arr_param/src/main.cm

import "libc/stdio"


func swap(x: [2]Int32) -> [2]Int32


func swap(x: [2]Int32) -> [2]Int32 {
    var out: [2]Int32
    out[0] = x[1]
    out[1] = x[0]
    return out
}


func ret_str() -> [7]Char8 {
    return "hello!\n"
}


func ret_str2() -> [2][10]Char8 {
    return ["ab", "cd"]
}


func kk(x: [2][10]Char8) -> Unit {
    printf("%c\n", x[0][0])
    printf("%c\n", x[0][1])
    printf("%c\n", x[0][2])
    printf("%c\n", x[0][3])
    printf("%c\n", x[0][4])
    printf("%c\n", x[0][5])
    printf("%c\n", x[0][6])
    printf("%c\n", x[0][7])
    printf("%c\n", x[0][8])
    printf("%c\n", x[0][9])
    printf("\n")

    printf("%c\n", x[1][0])
    printf("%c\n", x[1][1])
    printf("%c\n", x[1][2])
    printf("%c\n", x[1][3])
    printf("%c\n", x[1][4])
    printf("%c\n", x[1][5])
    printf("%c\n", x[1][6])
    printf("%c\n", x[1][7])
    printf("%c\n", x[1][8])
    printf("%c\n", x[1][9])
    printf("\n")
}



var global_array: [2]Int32 = [1, 2]


type Point record {
    x: Int32
    y: Int32
}

type Pod record {
    x: [10]Char8
}


func main() -> Int {

    // function returns array
    var returned_string: [7]Char8 = ret_str()
    printf("returned_string = %s", &returned_string)


    // function receive array & return array
    var a: [2]Int32

    a[0] = 10
    a[1] = 20

    printf("before swap:\n")
    printf("a[0] = %i\n", a[0])
    printf("a[1] = %i\n", a[1])

    let b = swap(a)

    printf("after swap:\n")
    printf("b[0] = %i\n", b[0])
    printf("b[1] = %i\n", b[1])



    var w: [2][10]Char8
    w[0] = "hello"
    w[1] = "world"
    let u = w
    kk(u)


    return 0
}

