// examples/arr_param/main.cm

@attribute("c-no-print")
import "libc/stdio.hm"


func swap(x: [2]Int32) -> [2]Int32


func swap(x: [2]Int32) -> [2]Int32 {
    var out: [2]Int32
    out[0] = x[1]
    out[1] = x[0]
    return out
}


var ga: [2]Int32 := [1, 2]

func main() -> Int {
    var a: [2]Int32

    a[0] = 10
    a[1] = 20

    let b = swap(a)

    printf("b[0] = %i\n", b[0])
    printf("b[1] = %i\n", b[1])

    let c = swap(ga)
    printf("c[0] = %i\n", c[0])
    printf("c[1] = %i\n", c[1])

    printf("hello world!\n")

    return 0
}

