// examples/arr_param/main.cm

@attribute("c-no-print")
import "libc/stdio.hm"


func swap(x: [2]Int32) -> [2]Int32


func swap(x: [2]Int32) -> [2]Int32 {
    var out: [2]Int32
    out[0] = x[1]
    out[1] = x[0]
    return out
}


var global_array: [2]Int32 := [1, 2]

func main() -> Int {
    var local_array: [2]Int32

    local_array[0] = 10
    local_array[1] = 20

    let a = swap(local_array)

    printf("a[0] = %i\n", a[0])
    printf("a[1] = %i\n", a[1])

    let b = swap(global_array)

    printf("b[0] = %i\n", b[0])
    printf("b[1] = %i\n", b[1])

    printf("hello world!\n")

    return 0
}

