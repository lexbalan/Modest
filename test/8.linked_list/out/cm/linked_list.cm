// examples/8.linked_list/linked_list.cm
import "libc/libc.h"

import "./linked_list.h"


type Node record {
    next : *Node
    prev : *Node
    link : Pointer
}

type List record {
    head : *Node
    tail : *Node
    size : Nat32
}


func linked_list_create () -> *List {
    let list = malloc((sizeof(List)))

    if list == nil {
        return nil
    }

    //list.size >= list.head

    list.head := nil
    list.tail := nil

    return list to *List
}


func linked_list_size_get (list : *List) -> Nat32 {
    if list == nil {
        return 0
    }

    return list.size
}


func linked_list_first_get (list : *List) -> *Node {
    if list == nil {
        return nil
    }

    return list.head to *Node
}


func linked_list_last_get (list : *List) -> *Node {
    if list == nil {
        return nil
    }

    return list.tail to *Node
}


func linked_list_node_create () -> *Node {
    let node = malloc((sizeof(Node)))

    if node == nil {
        return nil
    }

    node.prev := nil
    node.next := nil
    node.link := nil

    return node to *Node
}


func linked_list_node_next_get (node : *Node) -> *Node {
    if node == nil {
        return nil
    }

    return node.next to *Node
}


func linked_list_node_prev_get (node : *Node) -> *Node {
    if node == nil {
        return nil
    }

    return node.prev to *Node
}


func linked_list_node_link_get (node : *Node) -> Pointer {
    if node == nil {
        return nil
    }

    return node.link
}


func linked_list_insert_node (list : *List, new_node : *Node) -> *Node {
    if list == nil or new_node == nil {
        return nil
    }

    if list.head == nil {
        list.head := new_node to *Node
    }

    if list.tail != nil {
        let old_tail = list.tail
        old_tail.next := new_node to *Node
        new_node.prev := old_tail to *Node
    }

    list.tail := new_node to *Node
    list.size := list.size + 1

    return new_node to *Node
}

func linked_list_insert (list : *List, link : Pointer) -> *Node {
    if list == nil {
        return nil
    }

    let new_node = linked_list_node_create()

    if new_node == nil {
        return nil
    }

    new_node.link := link

    let node = linked_list_insert_node(list to *List, new_node to *Node)

    if node == nil {
        free(new_node)
    }

    return node to *Node
}

