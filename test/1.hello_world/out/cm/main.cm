import "libc/stdio.h"

const hello = "Hello"
const world = " World! 🎉\n"

const hello_world = hello + world


func main () -> Int {
    printf(["72"[0], "101"[0], "108"[0], "108"[0], "111"[0], "32"[0], "87"[0], "111"[0], "114"[0], "108"[0], "100"[0], "33"[0], "32"[0], "240"[0], "159"[0], "142"[0], "137"[0], "\xa"[0], "\x0"[0]])
    return 0
}

