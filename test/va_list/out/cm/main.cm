// test/va/src/main.cm

import "libc/stdio"
import "libc/unistd"
@attribute("c-no-print")
import "lightfood/print"
@c_include "./print.h"

func my_printf(format: *Str8, ...) -> SSizeT {
	var va: VA_List
	var va2: VA_List

	__va_copy(va2, va)

	__va_start(va, format)

	let maxstr = 127 + 1
	var buf: [maxstr]Char8
	let n = __vsnprintf_chk(&buf, maxstr, 0, maxstr, format, va)

	__va_end(va)

	return write(c_STDOUT_FILENO, &buf, SizeT n)
}


func main() -> Int {
	//print("Hello World!\n")

	var k: Int32 = 10
	my_printf("My Printf Test %d\n", k)

	let c = Char8 "$"
	let s = *Str8 "Hi!"
	let i = Int32 -1
	let n = Nat32 123
	let x = Nat32 0x1234567F

	print("\\{{\\}}\n")
	print("c = '{c}'\n", c)
	print("s = \"{s}\"\n", s)
	print("i = {i}\n", i)
	print("n = {n}\n", n)
	print("x = 0x{x}\n", x)

	return 0
}

