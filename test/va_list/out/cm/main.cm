import "libc/stdio"
import "libc/libc"
import "libc/unistd"

/*@attribute("c-no-print")
import "lightfood/print"
@c_include("./print.h")*/
func my_printf(format: *Str8, va_list: VA_List) -> SSizeT {
	let maxstr = 128 + 1
	var buf: [maxstr]Char8
	//let n = vsnprintf(&buf, maxstr, format, va_list)
	let n = __vsnprintf_chk(&buf, maxstr, 0, maxstr, format, va_list)
	return write(c_STDOUT_FILENO, &buf, SizeT n)
}


func main() -> Int {
	//print("Hello World!\n")

	var k: Int32 = 10
	my_printf("My Printf Test %d\n", k)

