// examples/

import "libc/stdio.hm"

@attribute("c-no-print")
import "lightfood/print.hm"
@c_include("./print.h")


func main() -> Int {
    lf_printf("Hello World!\n")

    let c = "$"[0] to Char8
    let s = "Hi!" to *Str8
    let i = -1 to Int32
    let n = 123 to Nat32
    let x = 0x1234567F to Nat32

	lf_printf("%% = '%%'\n")
	lf_printf("c = '%c'\n", c)
	lf_printf("s = \"%s\"\n", s)
	lf_printf("i = %i\n", i)
	lf_printf("n = %n\n", n)
	lf_printf("x = 0x%x\n", x)

    return 0
}

