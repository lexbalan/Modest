// examples/

@attribute("c-no-print")
import "libc/stdio.hm"

@attribute("c-no-print")
import "fastfood/print.hm"
@c_include("./print.h")


func main() -> Int {
    ff_printf("Hello World!\n")

    let c = "$"[0] to Char8
    let s = "Hi!" to *Str8
    let i = -1 to Int32
    let n = 123 to Nat32
    let x = 0x1234567F to Nat32

	ff_printf("%% = '%%'\n")
	ff_printf("c = '%c'\n", c)
	ff_printf("s = \"%s\"\n", s)
	ff_printf("i = %i\n", i)
	ff_printf("n = %n\n", n)
	ff_printf("x = 0x%x\n", x)

    return 0
}

