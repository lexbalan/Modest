// examples/

import "libc/stdio.hm"

@attribute("c-no-print")
import "lightfood/print.hm"
@c_include("./print.h")


func main() -> Int {
    print("Hello World!\n")

    let c = "$"[0] to Char8
    let s = "Hi!" to *Str8
    let i = -1 to Int32
    let n = 123 to Nat32
    let x = 0x1234567F to Nat32

	print("%% = '%%'\n")
	print("c = '%c'\n", c)
	print("s = \"%s\"\n", s)
	print("i = %i\n", i)
	print("n = %n\n", n)
	print("x = 0x%x\n", x)

    return 0
}

