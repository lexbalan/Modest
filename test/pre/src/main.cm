@property("c_alias", "arrshow")
@property("cm_alias", "arrshow")
func arrayShow(array: *Arr, size: sub::Int) -> Unit {
	console::printf("arrayShow:\n")
	var i = 0
	while i < 10 {
		console::printf("array[%d] = %d\n", i, array[i])
		++i
	}
}

type Data Nat32

type Node record {
	next: *Node
	data: *Data
}

let arrSize = 10
type Arr [arrSize]sub::Int

