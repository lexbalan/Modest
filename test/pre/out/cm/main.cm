func arrayShow(array: *Arr, size: Int) -> Unit {
	print("arrayShow:\n")
	var i: Int32 = 0
	while i < 10 {
		print("array[%d] = %d\n", i, array[i])
		i = i + 1
	}
}
func mid(a: Int, b: Int) -> Int {
	let sum = a + b
	return div(sum, 2)
}

