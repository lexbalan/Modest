// test/bool/src/main.cm

import "libc/stdio"



func main() -> Int {
    printf("bool check\nm")

    var x: Nat8
    var b: Bool

    x = 1
    b = Bool x
    printf("x = %i\n", Nat32 x)
    printf("x to Bool = %i\n", Nat32 b)

    x = 2
    b = Bool x
    printf("x = %i\n", Nat32 x)
    printf("x to Bool = %i\n", Nat32 b)

    x = 3
    b = Bool x
    printf("x = %i\n", Nat32 x)
    printf("x to Bool = %i\n", Nat32 b)

    return 0
}

