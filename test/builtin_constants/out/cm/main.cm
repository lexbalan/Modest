// test/builtin_constants/src/main.cm

import "libc/stdio"


func main() -> Int {
    printf("__compiler.name = %s\n", *Str8 {name = "m2", version = {major = 0, minor = 7}}.name)
    printf("__compiler.version.major = %u\n", {name = "m2", version = {major = 0, minor = 7}}.version.major)
    printf("__compiler.version.minor = %u\n", {name = "m2", version = {major = 0, minor = 7}}.version.minor)

    printf("__target.pointerWidth = %u\n", {charWidth = 8, intWidth = 32, floatWidth = 64, pointerWidth = 64}.pointerWidth)
    printf("__target.charWidth = %u\n", {charWidth = 8, intWidth = 32, floatWidth = 64, pointerWidth = 64}.charWidth)
    printf("__target.intWidth = %u\n", {charWidth = 8, intWidth = 32, floatWidth = 64, pointerWidth = 64}.intWidth)
    printf("__target.floatWidth = %u\n", {charWidth = 8, intWidth = 32, floatWidth = 64, pointerWidth = 64}.floatWidth)

    printf("__platformSystem = \"%s\"\n", *Str8 "Darwin")
    printf("__platformRelease = \"%s\"\n", *Str8 "21.6.0")

    return 0
}

