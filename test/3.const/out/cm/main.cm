import "libc/stdio.h"

const genericIntConst = 42
const int32Const = genericIntConst

const genericStringConst = "Hello!"
const string8Const = ["72"[0], "101"[0], "108"[0], "108"[0], "111"[0], "33"[0], "\x0"[0]]
const string16Const = ["72"[0], "101"[0], "108"[0], "108"[0], "111"[0], "33"[0], "\x0"[0]]
const string32Const = ["72"[0], "101"[0], "108"[0], "108"[0], "111"[0], "33"[0], "\x0"[0]]


type Point record {
    x : Nat32
    y : Nat32
}

const points = [
    {x = 0, y = 0}
    {x = 1, y = 1}
    {x = 2, y = 2}
]


// есть проблема - в C глобальные переменные с модификатором const
// не могут быть так инициализированы, поскольку points является приведением
// непонятно существует ли хорошее решение
//@property("c_prefix", "const")
var points2 : [3]Point := points


// define function main
func main () -> Int {
    printf(["116"[0], "101"[0], "115"[0], "116"[0], "32"[0], "99"[0], "111"[0], "110"[0], "115"[0], "116"[0], "\xa"[0], "\x0"[0]])

    printf(["103"[0], "101"[0], "110"[0], "101"[0], "114"[0], "105"[0], "99"[0], "73"[0], "110"[0], "116"[0], "67"[0], "111"[0], "110"[0], "115"[0], "116"[0], "32"[0], "61"[0], "32"[0], "37"[0], "100"[0], "\xa"[0], "\x0"[0]], genericIntConst)
    printf(["105"[0], "110"[0], "116"[0], "51"[0], "50"[0], "67"[0], "111"[0], "110"[0], "115"[0], "116"[0], "32"[0], "61"[0], "32"[0], "37"[0], "100"[0], "\xa"[0], "\x0"[0]], int32Const)

    //	printf("genericStringConst = %s\n", genericStringConst)
    printf(["115"[0], "116"[0], "114"[0], "105"[0], "110"[0], "103"[0], "56"[0], "67"[0], "111"[0], "110"[0], "115"[0], "116"[0], "32"[0], "61"[0], "32"[0], "37"[0], "115"[0], "\xa"[0], "\x0"[0]], string8Const)

    return 0
