// test/3.const/main.cm
import "libc/stdio.h"

const genericIntConst = 42
const int32Const = genericIntConst

const genericStringConst = "Hello!"
const string8Const = ["H"[0], "e"[0], "l"[0], "l"[0], "o"[0], "!"[0], "\x0"[0]]
const string16Const = ["H"[0], "e"[0], "l"[0], "l"[0], "o"[0], "!"[0], "\x0"[0]]
const string32Const = ["H"[0], "e"[0], "l"[0], "l"[0], "o"[0], "!"[0], "\x0"[0]]


type Point record {
    x : Nat32
    y : Nat32
}

const points = [
    {x = 0, y = 0}
    {x = 1, y = 1}
    {x = 2, y = 2}
]


// есть проблема - в C глобальные переменные с модификатором const
// не могут быть так инициализированы, поскольку points является приведением
// непонятно существует ли хорошее решение
//@property("c_prefix", "const")
var points2 : [3]Point := points


// define function main
func main () -> Int {
    printf(["t"[0], "e"[0], "s"[0], "t"[0], " "[0], "c"[0], "o"[0], "n"[0], "s"[0], "t"[0], "\xa"[0], "\x0"[0]])

    printf(["g"[0], "e"[0], "n"[0], "e"[0], "r"[0], "i"[0], "c"[0], "I"[0], "n"[0], "t"[0], "C"[0], "o"[0], "n"[0], "s"[0], "t"[0], " "[0], "="[0], " "[0], "%"[0], "d"[0], "\xa"[0], "\x0"[0]], genericIntConst)
    printf(["i"[0], "n"[0], "t"[0], "3"[0], "2"[0], "C"[0], "o"[0], "n"[0], "s"[0], "t"[0], " "[0], "="[0], " "[0], "%"[0], "d"[0], "\xa"[0], "\x0"[0]], int32Const)

    //	printf("genericStringConst = %s\n", genericStringConst)
    printf(["s"[0], "t"[0], "r"[0], "i"[0], "n"[0], "g"[0], "8"[0], "C"[0], "o"[0], "n"[0], "s"[0], "t"[0], " "[0], "="[0], " "[0], "%"[0], "s"[0], "\xa"[0], "\x0"[0]], string8Const)

    return 0
}

