// test/3.const/main.cm

@attribute("c-no-print")
import "libc/stdio.hm"

const perfectIntConst = 42
const int32Const = perfectIntConst to Int32

const perfectStringConst = "Hello!"
const string8Const = perfectStringConst to *Str8
const string16Const = perfectStringConst to *Str16
const string32Const = perfectStringConst to *Str32


type Point record {
    x : Nat32
    y : Nat32
}


const ps = [
    {x=0, y=0}
    {x=1, y=1}
    {x=2, y=2}
]

const points = ps to [3]Point


// есть проблема - в C глобальные переменные с модификатором const
// не могут быть так инициализированы, поскольку points является приведением
// непонятно существует ли хорошее решение
//@property("c_prefix", "const")
var points2 : [3]Point = points


// define function main
func main() -> Int {
    printf("test const\n")

	printf("perfectIntConst = %d\n", perfectIntConst to Int32)
	printf("int32Const = %d\n", int32Const)

//	printf("perfectStringConst = %s\n", perfectStringConst)
	printf("string8Const = %s\n", string8Const)

    return 0
}


