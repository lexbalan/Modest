// test/sizeof/main.cm
@attribute("c-no-print")
import "libc/stdio.h"


type Point record {
    x: Nat32
    y: Nat32
}

type Mixed1 record {
    c: Char8
    i: Int32
    f: Float64
}

type Mixed2 record {
    i: Int32
    c: Char8
    f: Float64
    c2: [3]Char8
    m: Mixed1record {
        c: Char8
        i: Int32
        f: Float64
    }
}

type Mixed3 record {
    c: Char8
    i: Int32
    f: Float64
    c2: [9]Char8
}

type Mixed4 record {
    s: Mixed2record {
        i: Int32
        c: Char8
        f: Float64
        c2: [3]Char8
        m: Mixed1record {
            c: Char8
            i: Int32
            f: Float64
        }
    }
    c: Char8
    i: Int32
    f: Float64
    c2: [9]Char8
    i2: Int16
    p: [3]Pointrecord {
        x: Nat32
        y: Nat32
    }
    s2: Mixed3record {
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
    }
}


//var s : Mixed2
var c: Char8
var i: Int32
var f: Float64
var i2: Int16
var p: [3]Pointrecord {
    x: Nat32
    y: Nat32
}
var g: Bool

type X record {
    c: Char8
    i: Int32
    f: Float64
    i2: Int16
    p: [3]Pointrecord {
        x: Nat32
        y: Nat32
    }
    g: Bool
}

var x: Xrecord {
    c: Char8
    i: Int32
    f: Float64
    i2: Int16
    p: [3]Pointrecord {
        x: Nat32
        y: Nat32
    }
    g: Bool
}

func main() -> IntInt {
    printf("test cast operation\n")

    let start_adr = &c to Nat64
    printf("off(c) = %llu\n", &c to Nat64 - start_adr)
    printf("off(i) = %llu\n", &i to Nat64 - start_adr)
    printf("off(f) = %llu\n", &f to Nat64 - start_adr)
    printf("off(i2) = %llu\n", &i2 to Nat64 - start_adr)
    printf("off(p) = %llu\n", &p to Nat64 - start_adr)
    printf("off(g) = %llu\n", &g to Nat64 - start_adr)

    // дженерики в с явно не приводятся, но нектороые нужно!
    printf("offsetof(x.c) = %llu\n", offsetof(Xrecord {
        c: Char8
        i: Int32
        f: Float64
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        g: Bool
    }.c) to Nat64)
    printf("offsetof(x.i) = %llu\n", offsetof(Xrecord {
        c: Char8
        i: Int32
        f: Float64
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        g: Bool
    }.i) to Nat64)
    printf("offsetof(x.f) = %llu\n", offsetof(Xrecord {
        c: Char8
        i: Int32
        f: Float64
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        g: Bool
    }.f) to Nat64)
    printf("offsetof(x.i2) = %llu\n", offsetof(Xrecord {
        c: Char8
        i: Int32
        f: Float64
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        g: Bool
    }.i2) to Nat64)
    printf("offsetof(x.p) = %llu\n", offsetof(Xrecord {
        c: Char8
        i: Int32
        f: Float64
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        g: Bool
    }.p) to Nat64)
    printf("offsetof(x.g) = %llu\n", offsetof(Xrecord {
        c: Char8
        i: Int32
        f: Float64
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        g: Bool
    }.g) to Nat64)


    // sizeof(void) in C  == 1
    // sizeof(Unit) in CM == 0
    // TODO: here is a broblem
    printf("sizeof(Unit) = %llu\n", sizeof(Unit) to Nat64)
    printf("alignof(Unit) = %llu\n", alignof(Unit) to Nat64)

    printf("sizeof(Bool) = %llu\n", sizeof(Bool) to Nat64)
    printf("alignof(Bool) = %llu\n", alignof(Bool) to Nat64)

    printf("sizeof(Nat8) = %llu\n", sizeof(Nat8) to Nat64)
    printf("alignof(Nat8) = %llu\n", alignof(Nat8) to Nat64)
    printf("sizeof(Nat16) = %llu\n", sizeof(Nat16) to Nat64)
    printf("alignof(Nat16) = %llu\n", alignof(Nat16) to Nat64)
    printf("sizeof(Nat32) = %llu\n", sizeof(Nat32) to Nat64)
    printf("alignof(Nat32) = %llu\n", alignof(Nat32) to Nat64)
    printf("sizeof(Nat64) = %llu\n", sizeof(Nat64) to Nat64)
    printf("alignof(Nat64) = %llu\n", alignof(Nat64) to Nat64)
    printf("sizeof(Nat128) = %llu\n", sizeof(Nat128) to Nat64)
    printf("alignof(Nat128) = %llu\n", alignof(Nat128) to Nat64)
    // type Nat256 not implemented
    //printf("sizeof(Nat256) = %llu\n", sizeof(Nat256) to Nat64)

    printf("sizeof(Int8) = %llu\n", sizeof(Int8) to Nat64)
    printf("alignof(Int8) = %llu\n", alignof(Int8) to Nat64)
    printf("sizeof(Int16) = %llu\n", sizeof(Int16) to Nat64)
    printf("alignof(Int16) = %llu\n", alignof(Int16) to Nat64)
    printf("sizeof(Int32) = %llu\n", sizeof(Int32) to Nat64)
    printf("alignof(Int32) = %llu\n", alignof(Int32) to Nat64)
    printf("sizeof(Int64) = %llu\n", sizeof(Int64) to Nat64)
    printf("alignof(Int64) = %llu\n", alignof(Int64) to Nat64)
    printf("sizeof(Int128) = %llu\n", sizeof(Int128) to Nat64)
    printf("alignof(Int128) = %llu\n", alignof(Int128) to Nat64)
    // type Int256 not implemented
    //printf("sizeof(Int256) = %llu\n", sizeof(Int256) to Nat64)

    printf("sizeof(Char8) = %llu\n", sizeof(Char8) to Nat64)
    printf("alignof(Char8) = %llu\n", alignof(Char8) to Nat64)
    printf("sizeof(Char16) = %llu\n", sizeof(Char16) to Nat64)
    printf("alignof(Char16) = %llu\n", alignof(Char16) to Nat64)
    printf("sizeof(Char32) = %llu\n", sizeof(Char32) to Nat64)
    printf("alignof(Char32) = %llu\n", alignof(Char32) to Nat64)

    // pointer size (for example pointer to []Char8)
    printf("sizeof(*Str8) = %llu\n", sizeof(*[]Char8) to Nat64)
    printf("alignof(*Str8) = %llu\n", alignof(*[]Char8) to Nat64)

    // array size
    printf("sizeof([10]Int32) = %llu\n", sizeof([10]Int32) to Nat64)
    printf("alignof([10]Int32) = %llu\n", alignof([10]Int32) to Nat64)

    printf("> alignof([3]Point) = %llu\n", alignof([3]Pointrecord {
        x: Nat32
        y: Nat32
    }) to Nat64)



    // record size
    printf("sizeof(Point) = %llu\n", sizeof(Pointrecord {
        x: Nat32
        y: Nat32
    }) to Nat64)
    printf("alignof(Point) = %llu\n", alignof(Pointrecord {
        x: Nat32
        y: Nat32
    }) to Nat64)

    printf("offsetof(Point.x) = %llu\n", offsetof(Pointrecord {
        x: Nat32
        y: Nat32
    }.x) to Nat64)
    printf("offsetof(Point.y) = %llu\n", offsetof(Pointrecord {
        x: Nat32
        y: Nat32
    }.y) to Nat64)


    printf("sizeof(Mixed1) = %llu\n", sizeof(Mixed1record {
        c: Char8
        i: Int32
        f: Float64
    }) to Nat64)
    printf("alignof(Mixed1) = %llu\n", alignof(Mixed1record {
        c: Char8
        i: Int32
        f: Float64
    }) to Nat64)

    printf("sizeof(Mixed2) = %llu\n", sizeof(Mixed2record {
        i: Int32
        c: Char8
        f: Float64
        c2: [3]Char8
        m: Mixed1record {
            c: Char8
            i: Int32
            f: Float64
        }
    }) to Nat64)
    printf("alignof(Mixed2) = %llu\n", alignof(Mixed2record {
        i: Int32
        c: Char8
        f: Float64
        c2: [3]Char8
        m: Mixed1record {
            c: Char8
            i: Int32
            f: Float64
        }
    }) to Nat64)


    printf("offsetof(Mixed2.i) = %llu\n", offsetof(Mixed2record {
        i: Int32
        c: Char8
        f: Float64
        c2: [3]Char8
        m: Mixed1record {
            c: Char8
            i: Int32
            f: Float64
        }
    }.i) to Nat64)
    printf("offsetof(Mixed2.c) = %llu\n", offsetof(Mixed2record {
        i: Int32
        c: Char8
        f: Float64
        c2: [3]Char8
        m: Mixed1record {
            c: Char8
            i: Int32
            f: Float64
        }
    }.c) to Nat64)
    printf("offsetof(Mixed2.f) = %llu\n", offsetof(Mixed2record {
        i: Int32
        c: Char8
        f: Float64
        c2: [3]Char8
        m: Mixed1record {
            c: Char8
            i: Int32
            f: Float64
        }
    }.f) to Nat64)
    printf("offsetof(Mixed2.c2) = %llu\n", offsetof(Mixed2record {
        i: Int32
        c: Char8
        f: Float64
        c2: [3]Char8
        m: Mixed1record {
            c: Char8
            i: Int32
            f: Float64
        }
    }.c2) to Nat64)
    printf("offsetof(Mixed2.m) = %llu\n", offsetof(Mixed2record {
        i: Int32
        c: Char8
        f: Float64
        c2: [3]Char8
        m: Mixed1record {
            c: Char8
            i: Int32
            f: Float64
        }
    }.m) to Nat64)


    printf("sizeof(Mixed3) = %llu\n", sizeof(Mixed3record {
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
    }) to Nat64)
    printf("alignof(Mixed3) = %llu\n", alignof(Mixed3record {
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
    }) to Nat64)

    printf("sizeof(Mixed4) = %llu\n", sizeof(Mixed4record {
        s: Mixed2record {
            i: Int32
            c: Char8
            f: Float64
            c2: [3]Char8
            m: Mixed1record {
                c: Char8
                i: Int32
                f: Float64
            }
        }
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        s2: Mixed3record {
            c: Char8
            i: Int32
            f: Float64
            c2: [9]Char8
        }
    }) to Nat64)
    printf("alignof(Mixed4) = %llu\n", alignof(Mixed4record {
        s: Mixed2record {
            i: Int32
            c: Char8
            f: Float64
            c2: [3]Char8
            m: Mixed1record {
                c: Char8
                i: Int32
                f: Float64
            }
        }
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        s2: Mixed3record {
            c: Char8
            i: Int32
            f: Float64
            c2: [9]Char8
        }
    }) to Nat64)

    printf("offsetof(Mixed4.s) = %llu\n", offsetof(Mixed4record {
        s: Mixed2record {
            i: Int32
            c: Char8
            f: Float64
            c2: [3]Char8
            m: Mixed1record {
                c: Char8
                i: Int32
                f: Float64
            }
        }
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        s2: Mixed3record {
            c: Char8
            i: Int32
            f: Float64
            c2: [9]Char8
        }
    }.s) to Nat64)
    printf("offsetof(Mixed4.c) = %llu\n", offsetof(Mixed4record {
        s: Mixed2record {
            i: Int32
            c: Char8
            f: Float64
            c2: [3]Char8
            m: Mixed1record {
                c: Char8
                i: Int32
                f: Float64
            }
        }
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        s2: Mixed3record {
            c: Char8
            i: Int32
            f: Float64
            c2: [9]Char8
        }
    }.c) to Nat64)
    printf("offsetof(Mixed4.i) = %llu\n", offsetof(Mixed4record {
        s: Mixed2record {
            i: Int32
            c: Char8
            f: Float64
            c2: [3]Char8
            m: Mixed1record {
                c: Char8
                i: Int32
                f: Float64
            }
        }
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        s2: Mixed3record {
            c: Char8
            i: Int32
            f: Float64
            c2: [9]Char8
        }
    }.i) to Nat64)
    printf("offsetof(Mixed4.f) = %llu\n", offsetof(Mixed4record {
        s: Mixed2record {
            i: Int32
            c: Char8
            f: Float64
            c2: [3]Char8
            m: Mixed1record {
                c: Char8
                i: Int32
                f: Float64
            }
        }
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        s2: Mixed3record {
            c: Char8
            i: Int32
            f: Float64
            c2: [9]Char8
        }
    }.f) to Nat64)
    printf("offsetof(Mixed4.c2) = %llu\n", offsetof(Mixed4record {
        s: Mixed2record {
            i: Int32
            c: Char8
            f: Float64
            c2: [3]Char8
            m: Mixed1record {
                c: Char8
                i: Int32
                f: Float64
            }
        }
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        s2: Mixed3record {
            c: Char8
            i: Int32
            f: Float64
            c2: [9]Char8
        }
    }.c2) to Nat64)
    printf("offsetof(Mixed4.i2) = %llu\n", offsetof(Mixed4record {
        s: Mixed2record {
            i: Int32
            c: Char8
            f: Float64
            c2: [3]Char8
            m: Mixed1record {
                c: Char8
                i: Int32
                f: Float64
            }
        }
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        s2: Mixed3record {
            c: Char8
            i: Int32
            f: Float64
            c2: [9]Char8
        }
    }.i2) to Nat64)
    printf("offsetof(Mixed4.p) = %llu\n", offsetof(Mixed4record {
        s: Mixed2record {
            i: Int32
            c: Char8
            f: Float64
            c2: [3]Char8
            m: Mixed1record {
                c: Char8
                i: Int32
                f: Float64
            }
        }
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        s2: Mixed3record {
            c: Char8
            i: Int32
            f: Float64
            c2: [9]Char8
        }
    }.p) to Nat64)
    printf("offsetof(Mixed4.s2) = %llu\n", offsetof(Mixed4record {
        s: Mixed2record {
            i: Int32
            c: Char8
            f: Float64
            c2: [3]Char8
            m: Mixed1record {
                c: Char8
                i: Int32
                f: Float64
            }
        }
        c: Char8
        i: Int32
        f: Float64
        c2: [9]Char8
        i2: Int16
        p: [3]Pointrecord {
            x: Nat32
            y: Nat32
        }
        s2: Mixed3record {
            c: Char8
            i: Int32
            f: Float64
            c2: [9]Char8
        }
