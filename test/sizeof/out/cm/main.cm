// test/sizeof/main.cm
import "libc/stdio.h"


type Point record {
    x: Nat32
    y: Nat32
}

type Mixed1 record {
    c: Char8
    i: Int32
    f: Float64
}

type Mixed2 record {
    c: Char8
    i: Int32
    f: Float64
    c2: Char8
}

type Mixed3 record {
    c: Char8
    i: Int32
    f: Float64
    c2: [9]Char8
}

type Mixed4 record {
    s: Mixed2
    c: Char8
    i: Int32
    f: Float64
    c2: [9]Char8
    i2: Int16
    p: [3]Point
    s2: Mixed3
}


func main() -> Int {
    printf("test cast operation\n")

    // sizeof(void) in C  == 1
    // sizeof(Unit) in CM == 0
    // TODO: here is a broblem
    printf("sizeof(Unit) = %lu\n", (sizeof(Unit)))
    printf("alignof(Unit) = %lu\n", (alignof(Unit)))

    printf("sizeof(Bool) = %lu\n", (sizeof(Bool)))
    printf("alignof(Bool) = %lu\n", (alignof(Bool)))

    printf("sizeof(Nat8) = %lu\n", (sizeof(Nat8)))
    printf("alignof(Nat8) = %lu\n", (alignof(Nat8)))
    printf("sizeof(Nat16) = %lu\n", (sizeof(Nat16)))
    printf("alignof(Nat16) = %lu\n", (alignof(Nat16)))
    printf("sizeof(Nat32) = %lu\n", (sizeof(Nat32)))
    printf("alignof(Nat32) = %lu\n", (alignof(Nat32)))
    printf("sizeof(Nat64) = %lu\n", (sizeof(Nat64)))
    printf("alignof(Nat64) = %lu\n", (alignof(Nat64)))
    printf("sizeof(Nat128) = %lu\n", (sizeof(Nat128)))
    printf("alignof(Nat128) = %lu\n", (alignof(Nat128)))
    // type Nat256 not implemented
    //printf("sizeof(Nat256) = %lu\n", sizeof(Nat256) to Nat64)

    printf("sizeof(Int8) = %lu\n", (sizeof(Int8)))
    printf("alignof(Int8) = %lu\n", (alignof(Int8)))
    printf("sizeof(Int16) = %lu\n", (sizeof(Int16)))
    printf("alignof(Int16) = %lu\n", (alignof(Int16)))
    printf("sizeof(Int32) = %lu\n", (sizeof(Int32)))
    printf("alignof(Int32) = %lu\n", (alignof(Int32)))
    printf("sizeof(Int64) = %lu\n", (sizeof(Int64)))
    printf("alignof(Int64) = %lu\n", (alignof(Int64)))
    printf("sizeof(Int128) = %lu\n", (sizeof(Int128)))
    printf("alignof(Int128) = %lu\n", (alignof(Int128)))
    // type Int256 not implemented
    //printf("sizeof(Int256) = %lu\n", sizeof(Int256) to Nat64)

    printf("sizeof(Char8) = %lu\n", (sizeof(Char8)))
    printf("alignof(Char8) = %lu\n", (alignof(Char8)))
    printf("sizeof(Char16) = %lu\n", (sizeof(Char16)))
    printf("alignof(Char16) = %lu\n", (alignof(Char16)))
    printf("sizeof(Char32) = %lu\n", (sizeof(Char32)))
    printf("alignof(Char32) = %lu\n", (alignof(Char32)))

    // pointer size (for example pointer to []Char8)
    printf("sizeof(*Str8) = %lu\n", (sizeof(*[]Char8)))
    printf("alignof(*Str8) = %lu\n", (alignof(*[]Char8)))

    // array size
    printf("sizeof([10]Int32) = %lu\n", (sizeof([10]Int32)))
    printf("alignof([10]Int32) = %lu\n", (alignof([10]Int32)))

    printf("> alignof([3]Point) = %lu\n", (alignof([3]Point)))



    // record size
    printf("sizeof(Point) = %lu\n", (sizeof(Point)))
    printf("alignof(Point) = %lu\n", (alignof(Point)))

    printf("offsetof(Point.x) = %lu\n", (offsetof(Point.x)))
    printf("offsetof(Point.y) = %lu\n", (offsetof(Point.y)))


    printf("sizeof(Mixed1) = %lu\n", (sizeof(Mixed1)))
    printf("alignof(Mixed1) = %lu\n", (alignof(Mixed1)))

    printf("sizeof(Mixed2) = %lu\n", (sizeof(Mixed2)))
    printf("alignof(Mixed2) = %lu\n", (alignof(Mixed2)))

    printf("sizeof(Mixed3) = %lu\n", (sizeof(Mixed3)))
    printf("alignof(Mixed3) = %lu\n", (alignof(Mixed3)))

    printf("sizeof(Mixed4) = %lu\n", (sizeof(Mixed4)))
    printf("alignof(Mixed4) = %lu\n", (alignof(Mixed4)))

    printf("offsetof(Mixed4.s) = %lu\n", (offsetof(Mixed4.s)))
    printf("offsetof(Mixed4.c) = %lu\n", (offsetof(Mixed4.c)))
    printf("offsetof(Mixed4.i) = %lu\n", (offsetof(Mixed4.i)))
    printf("offsetof(Mixed4.f) = %lu\n", (offsetof(Mixed4.f)))
    printf("offsetof(Mixed4.c2) = %lu\n", (offsetof(Mixed4.c2)))
    printf("offsetof(Mixed4.i2) = %lu\n", (offsetof(Mixed4.i2)))
    printf("offsetof(Mixed4.p) = %lu\n", (offsetof(Mixed4.p)))
    printf("offsetof(Mixed4.s2) = %lu\n", (offsetof(Mixed4.s2)))

    return 0
}

