        0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2
    ] to [64]Nat32


func sha256_transform(ctx: *SHA256_Context, data: *[]Nat8) -> Unit {
    var m : [64]Nat32 := []

    var i := 0 to Nat32
    var j := 0 to Nat32

    while i < 16 {
        let x = (data[j + 0] to Nat32 << 24) or (data[j + 1] to Nat32 << 16) or (data[j + 2] to Nat32 << 08) or (data[j + 3] to Nat32 << 00)

        m[i] := x
        j := j + 4
        i := i + 1
    }

    while i < 64 {
        m[i] := sig1(m[i - 2]) + m[i - 7] + sig0(m[i - 15]) + m[i - 16]
        i := i + 1
    }

    var x : [8]Nat32// := ctx.state
    memcpy(&x, &ctx.state, 8*4)

    i := 0
    while i < 64 {
        let t1 = x[7] + ep1(x[4]) + ch(x[4], x[5], x[6]) + k[i] + m[i]
        let t2 = ep0(x[0]) + maj(x[0], x[1], x[2])

        x[7] := x[6]
        x[6] := x[5]
        x[5] := x[4]
        x[4] := x[3] + t1
        x[3] := x[2]
        x[2] := x[1]
        x[1] := x[0]
        x[0] := t1 + t2

        i := i + 1
    }

    i := 0
    while i < 8 {
        ctx.state[i] := ctx.state[i] + x[i]
        i := i + 1
    }
}



func sha256_update(ctx: *SHA256_Context, data: *[]Nat8, len: Nat32) -> Unit {
    var i := 0 to Nat32
    while i < len {
        ctx.data[ctx.datalen] := data[i]
        ctx.datalen := ctx.datalen + 1
        if ctx.datalen == 64 {
            sha256_transform(ctx, &ctx.data)
            ctx.bitlen := ctx.bitlen + 512
            ctx.datalen := 0
        }
        i := i + 1
    }
}


func sha256_final(ctx: *SHA256_Context, hash: *[]Nat8) -> Unit {
    var i : Nat32 := ctx.datalen

    // Pad whatever data is left in the buffer.

    var n := 64 to Nat32
    if ctx.datalen < 56 {
        n := 56
    }

    ctx.data[i] := 0x80

    i := i + 1

    memset(&ctx.data[i], 0, (n - i) to SizeT)

    if ctx.datalen >= 56 {
        sha256_transform(ctx, &ctx.data)
        memset(&ctx.data, 0, 56)
    }

    // Append to the padding the total message's length in bits and transform.
    ctx.bitlen := ctx.bitlen + ctx.datalen to Nat64 * 8

    ctx.data[63] := (ctx.bitlen >> 00) to Nat8
    ctx.data[62] := (ctx.bitlen >> 08) to Nat8
    ctx.data[61] := (ctx.bitlen >> 16) to Nat8
    ctx.data[60] := (ctx.bitlen >> 24) to Nat8
    ctx.data[59] := (ctx.bitlen >> 32) to Nat8
    ctx.data[58] := (ctx.bitlen >> 40) to Nat8
    ctx.data[57] := (ctx.bitlen >> 48) to Nat8
    ctx.data[56] := (ctx.bitlen >> 56) to Nat8

    sha256_transform(ctx, &ctx.data)

    // Since this implementation uses little endian byte ordering
    // and SHA uses big endian, reverse all the bytes
    // when copying the final state to the output hash.

    i := 0
    while i < 4 {
        hash[i + 00] := (ctx.state[0] >> (24 - i * 8)) to Nat8
        hash[i + 04] := (ctx.state[1] >> (24 - i * 8)) to Nat8
        hash[i + 08] := (ctx.state[2] >> (24 - i * 8)) to Nat8
        hash[i + 12] := (ctx.state[3] >> (24 - i * 8)) to Nat8
        hash[i + 16] := (ctx.state[4] >> (24 - i * 8)) to Nat8
        hash[i + 20] := (ctx.state[5] >> (24 - i * 8)) to Nat8
        hash[i + 24] := (ctx.state[6] >> (24 - i * 8)) to Nat8
        hash[i + 28] := (ctx.state[7] >> (24 - i * 8)) to Nat8
        i := i + 1
    }
}


// arg hash must be at least SHA256_BLOCK_SIZE
func sha256_doHash(msg: *[]Nat8, len: Nat32, hash: *[]Nat8) -> Unit {
    var ctx := {} to SHA256_Context
    sha256_contextInit(&ctx)
    sha256_update(&ctx, msg, len)
    sha256_final(&ctx, hash)
}





type SHA256_TestData record {
    input : [32]Nat8
    input_len : Nat32
    output : [32]Nat8
}

var test0 : SHA256_TestData := {
    input = "abc"
    input_len = 3

    output = [0xBA, 0x78, 0x16, 0xBF, 0x8F, 0x01, 0xCF, 0xEA, 0x41, 0x41, 0x40, 0xDE, 0x5D, 0xAE, 0x22, 0x23, 0xB0, 0x03, 0x61, 0xA3, 0x96, 0x17, 0x7A, 0x9C, 0xB4, 0x10, 0xFF, 0x61, 0xF2, 0x00, 0x15, 0xAD]
}


var test1 : SHA256_TestData := {
    input = "Hello World!"
    input_len = 12

    output = [0x7F, 0x83, 0xB1, 0x65, 0x7F, 0xF1, 0xFC, 0x53, 0xB9, 0x2D, 0xC1, 0x81, 0x48, 0xA1, 0xD6, 0x5D, 0xFC, 0x2D, 0x4B, 0x1F, 0xA3, 0xD6, 0x77, 0x28, 0x4A, 0xDD, 0xD2, 0x00, 0x12, 0x6D, 0x90, 0x69]
}


const nTests = 2
var sha256_tests : [nTests]*SHA256_TestData := [&test0, &test1]



func sha256_doTest(test : *SHA256_TestData) -> Bool {
    var test_hash : [sha256HashSize]Nat8
    sha256_doHash(&test.input, test.input_len, &test_hash)


    printf("'%s'", &test.input)

    printf(" -> ")

    var i := 0
    while i < sha256HashSize {
        printf("%02X", test_hash[i])
        i := i + 1
    }

    printf("\n")


    let is_eq = memcmp(&test.output, &test_hash, sha256HashSize) == 0

    return is_eq
}


var test_msg : [13]Nat8 := "Hello World!"
var test_hash : [sha256HashSize]Nat8


func main () -> Int {
    printf("test SHA256\n")

    var i := 0
    while i < nTests {
        let test_result = sha256_doTest(sha256_tests[i])

        if test_result {
            printf("test #%d passed\n", i)
        } else {
            printf("test #%d failed\n", i)
        }

        i := i + 1
    }


