// test/sha256/main.cm
import "libc/stdio.h"
import "libc/libc.h"
import "misc/sha256.h"



type TestInputString [32]Char8

type SHA256_TestData record {
    input : TestInputString
    input_len : Nat32
    output : [32]Nat8
}


var test0 : SHA256_TestData := {
    input = ["97"[0], "98"[0], "99"[0]]
    input_len = 3

    output = [
        0xBA 0x78, 0x16, 0xBF, 0x8F, 0x01, 0xCF, 0xEA, 0x41, 0x41, 0x40,
        0xDE 0x5D, 0xAE, 0x22, 0x23, 0xB0, 0x03, 0x61, 0xA3, 0x96, 0x17,
        0x7A 0x9C, 0xB4, 0x10, 0xFF, 0x61, 0xF2, 0x00, 0x15, 0xAD
    ]
}

var test1 : SHA256_TestData := {
    input = ["72"[0], "101"[0], "108"[0], "108"[0], "111"[0], "32"[0], "87"[0], "111"[0], "114"[0], "108"[0], "100"[0], "33"[0]]
    input_len = 12

    output = [
        0x7F 0x83, 0xB1, 0x65, 0x7F, 0xF1, 0xFC, 0x53, 0xB9, 0x2D, 0xC1,
        0x81 0x48, 0xA1, 0xD6, 0x5D, 0xFC, 0x2D, 0x4B, 0x1F, 0xA3, 0xD6,
        0x77 0x28, 0x4A, 0xDD, 0xD2, 0x00, 0x12, 0x6D, 0x90, 0x69
    ]
}


const nTests = 2
var sha256_tests : [nTests]*SHA256_TestData := [&test0 to *SHA256_TestData, &test1 to *SHA256_TestData]


func sha256_doTest (test : *SHA256_TestData) -> Bool {
    var test_hash : [sha256HashSize]Nat8
    sha256_doHash(&test.input to *[]Nat8, test.input_len, &test_hash to *[]Nat8)

    printf(["39"[0], "37"[0], "115"[0], "39"[0], "\x0"[0]], &test.input)

    printf(["32"[0], "45"[0], "62"[0], "32"[0], "\x0"[0]])

    var i : Int32 := 0
    while i < sha256HashSize {
        printf(["37"[0], "48"[0], "50"[0], "88"[0], "\x0"[0]], test_hash[i])
        i := i + 1
    }

    printf(["\xa"[0], "\x0"[0]])

    let is_eq = memcmp(&test.output, &test_hash, sha256HashSize) == 0
    return is_eq
}


func main () -> Int {
    printf(["116"[0], "101"[0], "115"[0], "116"[0], "32"[0], "83"[0], "72"[0], "65"[0], "50"[0], "53"[0], "54"[0], "\xa"[0], "\x0"[0]])

    var i : Int32 := 0
    while i < nTests {
        let test = sha256_tests[i]
        let test_result = sha256_doTest(test to *SHA256_TestData)

        if test_result {
            printf(["116"[0], "101"[0], "115"[0], "116"[0], "32"[0], "35"[0], "37"[0], "100"[0], "32"[0], "112"[0], "97"[0], "115"[0], "115"[0], "101"[0], "100"[0], "\xa"[0], "\x0"[0]], i)
        } else {
            printf(["116"[0], "101"[0], "115"[0], "116"[0], "32"[0], "35"[0], "37"[0], "100"[0], "32"[0], "102"[0], "97"[0], "105"[0], "108"[0], "101"[0], "100"[0], "\xa"[0], "\x0"[0]], i)
        }

        i := i + 1
    }

    return 0
}

