]


func sha256_contextInit (ctx : *SHA256_Context) -> Unit {
    //ctx.state := initMagic
    memcpy(&ctx.state, &initMagic, (8 * 4))
}



//const k = [
var k : [64]Nat32 := [0x428A2F98, 0x71374491, 0xB5C0FBCF, 0xE9B5DBA5, 0x3956C25B, 0x59F111F1, 0x923F82A4, 0xAB1C5ED5, 0xD807AA98, 0x12835B01, 0x243185BE, 0x550C7DC3, 0x72BE5D74, 0x80DEB1FE, 0x9BDC06A7, 0xC19BF174, 0xE49B69C1, 0xEFBE4786, 0x0FC19DC6, 0x240CA1CC, 0x2DE92C6F, 0x4A7484AA, 0x5CB0A9DC, 0x76F988DA, 0x983E5152, 0xA831C66D, 0xB00327C8, 0xBF597FC7, 0xC6E00BF3, 0xD5A79147, 0x06CA6351, 0x14292967, 0x27B70A85, 0x2E1B2138, 0x4D2C6DFC, 0x53380D13, 0x650A7354, 0x766A0ABB, 0x81C2C92E, 0x92722C85, 0xA2BFE8A1, 0xA81A664B, 0xC24B8B70, 0xC76C51A3, 0xD192E819, 0xD6990624, 0xF40E3585, 0x106AA070, 0x19A4C116, 0x1E376C08, 0x2748774C, 0x34B0BCB5, 0x391C0CB3, 0x4ED8AA4A, 0x5B9CCA4F, 0x682E6FF3, 0x748F82EE, 0x78A5636F, 0x84C87814, 0x8CC70208, 0x90BEFFFA, 0xA4506CEB, 0xBEF9A3F7, 0xC67178F2
]


func sha256_transform (ctx : *SHA256_Context, data : *[]Nat8) -> Unit {
    var m : [64]Nat32 := []

    var i : Nat32 := 0 to Nat32
    var j : Nat32 := 0 to Nat32

    while i < 16 {
        let x = (data[j + 0] to Nat32) << 24 or (data[j + 1] to Nat32) << 16 or (data[j + 2] to Nat32) << 8 or (data[j + 3] to Nat32) << 0

        m[i] := x
        j := j + 4
        i := i + 1
    }

    while i < 64 {
        m[i] := sig1(m[i - 2]) + m[i - 7] + sig0(m[i - 15]) + m[i - 16]
        i := i + 1
    }

    var x : [8]Nat32
    memcpy(&x, &ctx.state, (8 * 4))

    i := 0
    while i < 64 {
        let t1 = x[7] + ep1(x[4]) + ch(x[4], x[5], x[6]) + k[i] + m[i]
        let t2 = ep0(x[0]) + maj(x[0], x[1], x[2])

        x[7] := x[6]
        x[6] := x[5]
        x[5] := x[4]
        x[4] := x[3] + t1
        x[3] := x[2]
        x[2] := x[1]
        x[1] := x[0]
        x[0] := t1 + t2

        i := i + 1
    }

    i := 0
    while i < 8 {
        ctx.state[i] := ctx.state[i] + x[i]
        i := i + 1
    }
}



func sha256_update (ctx : *SHA256_Context, data : *[]Nat8, len : Nat32) -> Unit {
    var i : Nat32 := 0 to Nat32
    while i < len {
        ctx.data[ctx.datalen] := data[i]
        ctx.datalen := ctx.datalen + 1
        if ctx.datalen == 64 {
            sha256_transform(ctx to *SHA256_Context, &ctx.data to *[]Nat8)
            ctx.bitlen := ctx.bitlen + 512
            ctx.datalen := 0
        }
        i := i + 1
    }
}


func sha256_final (ctx : *SHA256_Context, hash : *[]Nat8) -> Unit {
    var i : Nat32 := ctx.datalen

    // Pad whatever data is left in the buffer.

    var n : Nat32 := 64 to Nat32
    if ctx.datalen < 56 {
        n := 56
    }

    ctx.data[i] := 0x80

    i := i + 1

    memset(&ctx.data[i], 0, n - i to SizeT)

    if ctx.datalen >= 56 {
        sha256_transform(ctx to *SHA256_Context, &ctx.data to *[]Nat8)
        memset(&ctx.data, 0, 56)
    }

    // Append to the padding the total message's length in bits and transform.
    ctx.bitlen := ctx.bitlen + ctx.datalen to Nat64 * 8

    ctx.data[63] := ctx.bitlen >> 0 to Nat8
    ctx.data[62] := ctx.bitlen >> 8 to Nat8
    ctx.data[61] := ctx.bitlen >> 16 to Nat8
    ctx.data[60] := ctx.bitlen >> 24 to Nat8
    ctx.data[59] := ctx.bitlen >> 32 to Nat8
    ctx.data[58] := ctx.bitlen >> 40 to Nat8
    ctx.data[57] := ctx.bitlen >> 48 to Nat8
    ctx.data[56] := ctx.bitlen >> 56 to Nat8

    sha256_transform(ctx to *SHA256_Context, &ctx.data to *[]Nat8)

    // Since this implementation uses little endian byte ordering
    // and SHA uses big endian, reverse all the bytes
    // when copying the final state to the output hash.

    i := 0
    while i < 4 {
        let sh = 24 - i * 8
        hash[i + 0] := (ctx.state[0]) >> sh to Nat8
        hash[i + 4] := (ctx.state[1]) >> sh to Nat8
        hash[i + 8] := (ctx.state[2]) >> sh to Nat8
        hash[i + 12] := (ctx.state[3]) >> sh to Nat8
        hash[i + 16] := (ctx.state[4]) >> sh to Nat8
        hash[i + 20] := (ctx.state[5]) >> sh to Nat8
        hash[i + 24] := (ctx.state[6]) >> sh to Nat8
        hash[i + 28] := (ctx.state[7]) >> sh to Nat8
        i := i + 1
    }
}


// arg hash must be at least SHA256_BLOCK_SIZE
func sha256_doHash (msg : *[]Nat8, len : Nat32, hash : *[]Nat8) -> Unit {
    var ctx : SHA256_Context := {}
    sha256_contextInit(&ctx to *SHA256_Context)
    sha256_update(&ctx to *SHA256_Context, msg, len)
    sha256_final(&ctx to *SHA256_Context, hash)
}





type SHA256_TestData record {
    input : [32]Nat8
    input_len : Nat32
    output : [32]Nat8
}

var test0 : SHA256_TestData := {
    input = [97, 98, 99, 0]
    input_len = 3

    output = [0xBA, 0x78, 0x16, 0xBF, 0x8F, 0x01, 0xCF, 0xEA, 0x41, 0x41, 0x40, 0xDE, 0x5D, 0xAE, 0x22, 0x23, 0xB0, 0x03, 0x61, 0xA3, 0x96, 0x17, 0x7A, 0x9C, 0xB4, 0x10, 0xFF, 0x61, 0xF2, 0x00, 0x15, 0xAD]
}


var test1 : SHA256_TestData := {
    input = [72, 101, 108, 108, 111, 32, 87, 111, 114, 108, 100, 33, 0]
    input_len = 12

    output = [0x7F, 0x83, 0xB1, 0x65, 0x7F, 0xF1, 0xFC, 0x53, 0xB9, 0x2D, 0xC1, 0x81, 0x48, 0xA1, 0xD6, 0x5D, 0xFC, 0x2D, 0x4B, 0x1F, 0xA3, 0xD6, 0x77, 0x28, 0x4A, 0xDD, 0xD2, 0x00, 0x12, 0x6D, 0x90, 0x69]
}


const nTests = 2
var sha256_tests : [nTests]*SHA256_TestData := [&test0 to *SHA256_TestData, &test1 to *SHA256_TestData]



func sha256_doTest (test : *SHA256_TestData) -> Nat1 {
    var test_hash : [sha256HashSize]Nat8
    sha256_doHash(&test.input to *[]Nat8, test.input_len, &test_hash to *[]Nat8)


    printf("'%s'", &test.input)

    printf(" -> ")

    var i : Int32 := 0 to Int32
    while i < sha256HashSize {
        printf("%02X", test_hash[i])
        i := i + 1
    }

    printf("\n")


    let is_eq = memcmp(&test.output, &test_hash, sha256HashSize) == 0

    return is_eq
}


var test_msg : [13]Nat8 := [72, 101, 108, 108, 111, 32, 87, 111, 114, 108, 100, 33, 0]
var test_hash : [sha256HashSize]Nat8


func main () -> Int {
    printf("test SHA256\n")

    var i : Int32 := 0 to Int32
    while i < nTests {
        let test_result = sha256_doTest(sha256_tests[i] to *SHA256_TestData)

        if test_result {
            printf("test #%d passed\n", i)
        } else {
            printf("test #%d failed\n", i)
        }

        i := i + 1
    }


