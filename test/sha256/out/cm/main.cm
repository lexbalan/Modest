// test/sha256/src/main.cm

import "libc/stdio.h"
import "libc/libc.h"
@attribute("c-no-print")
import "misc/sha256.h"
@c_include "./sha256.h"


const INPUT_LENGTH = 32
const OUTPUT_LENGTH = sha256HashSize


type SHA256_TestCase record {
    input_data: [INPUT_LENGTH]Char8
    input_data_len: Nat32

    expected_result: [OUTPUT_LENGTH]Byte
}


var test0: SHA256_TestCase = {
    input_data = "abc"
    input_data_len = 3

    expected_result = [
        0xBA 0x78, 0x16, 0xBF, 0x8F, 0x01, 0xCF, 0xEA,
        0x41 0x41, 0x40, 0xDE, 0x5D, 0xAE, 0x22, 0x23,
        0xB0 0x03, 0x61, 0xA3, 0x96, 0x17, 0x7A, 0x9C,
        0xB4 0x10, 0xFF, 0x61, 0xF2, 0x00, 0x15, 0xAD
    ]
}

var test1: SHA256_TestCase = {
    input_data = "Hello World!"
    input_data_len = 12

    expected_result = [
        0x7F 0x83, 0xB1, 0x65, 0x7F, 0xF1, 0xFC, 0x53,
        0xB9 0x2D, 0xC1, 0x81, 0x48, 0xA1, 0xD6, 0x5D,
        0xFC 0x2D, 0x4B, 0x1F, 0xA3, 0xD6, 0x77, 0x28,
        0x4A 0xDD, 0xD2, 0x00, 0x12, 0x6D, 0x90, 0x69
    ]
}


var sha256_tests: [2]*SHA256_TestCase = [&test0, &test1]


func sha256_doTest(test: *SHA256_TestCase) -> Bool {
    var test_hash: [sha256HashSize]Byte
    sha256_doHash(&test.input_data to *[]Byte, test.input_data_len, &test_hash)

    printf("'%s'", &test.input_data)
    printf(" -> ")

    var i: Int32 = 0
    while i < sha256HashSize {
        printf("%02X", test_hash[i])
        i = i + 1
    }

    printf("\n")

    let test_passed = test_hash == test.expected_result

    return test_passed
}


func main() -> Int {
    printf("test SHA256\n")

    var i: Int32 = 0
    while i < (lengthof(sha256_tests)) {
        let test = sha256_tests[i]
        let test_result = sha256_doTest(test)

        printf("test #%i: ", i)
        if test_result {
            printf("passed\n")
        } else {
            printf("failed\n")
        }

        i = i + 1
    }

    return 0
}

