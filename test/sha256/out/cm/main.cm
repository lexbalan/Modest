// test/sha256/src/main.cm

import "libc/stdio"
import "libc/libc"
@attribute("c-no-print")
import "misc/sha256"
@c_include "./sha256.h"


let inputLength = 32
let outputLength = sha256HashSize


type SHA256_TestCase record {
	input_data: [inputLength]Char8
	input_data_len: Nat32

	expected_result: [outputLength]Byte
}


var test0: SHA256_TestCase = {
	input_data = "abc"
	input_data_len = 3

	expected_result = [
		0xBA, None 0x78, None 0x16, 0xBF, 0x8F, None 0x01, 0xCF, 0xEA
		None 0x41, None 0x41, None 0x40, 0xDE, None 0x5D, 0xAE, None 0x22, None 0x23
		0xB0, None 0x03, None 0x61, 0xA3, 0x96, None 0x17, None 0x7A, 0x9C
		0xB4, None 0x10, 0xFF, None 0x61, 0xF2, None 0x00, None 0x15, 0xAD
	]
}

var test1: SHA256_TestCase = {
	input_data = "Hello World!"
	input_data_len = 12

	expected_result = [
		None 0x7F, 0x83, 0xB1, None 0x65, None 0x7F, 0xF1, 0xFC, None 0x53
		0xB9, None 0x2D, 0xC1, 0x81, None 0x48, 0xA1, 0xD6, None 0x5D
		0xFC, None 0x2D, None 0x4B, None 0x1F, 0xA3, 0xD6, None 0x77, None 0x28
		None 0x4A, 0xDD, 0xD2, None 0x00, None 0x12, None 0x6D, 0x90, None 0x69
	]
}


//var sha256_tests: []*SHA256_TestCase = [&test0, &test1]
var sha256_tests: [2]*SHA256_TestCase = [&test0, &test1]


func sha256_doTest(test: *SHA256_TestCase) -> Bool {
	var test_hash: [sha256HashSize]Byte
	let msg = *[]Byte &test.input_data
	let msg_len = test.input_data_len
	sha256_doHash(msg, msg_len, &test_hash)

	printf("'%s'", &test.input_data)
	printf(" -> ")

	var i: Int32 = Int32 0
	while i < Int32 sha256HashSize {
		printf("%02X", test_hash[i])
		i = i + 1
	}

	printf("\n")

	let test_passed = test_hash == test.expected_result

	return test_passed
}


func main() -> Int {
	printf("test SHA256\n")

	var i: Int32 = Int32 0
	while i < Int lengthof(sha256_tests) {
		let test = sha256_tests[i]
		let test_result = sha256_doTest(test)

		var res: *Str8 = *Str8 "failed"
		if test_result {
			res = "passed"
		}

		printf("test #%i: %s\n", i, res)

		i = i + 1
	}

	return Int 0
}

