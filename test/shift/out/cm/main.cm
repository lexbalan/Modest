// examples/1.hello_world/main.cm
import "libc/stdio.h"



func main () -> Int {
    printf(["116"[0], "101"[0], "115"[0], "116"[0], "32"[0], "115"[0], "104"[0], "105"[0], "102"[0], "116"[0], "\xa"[0], "\x0"[0]])

    var c : Int32

    c := (1 << 31)
    printf(["49"[0], "32"[0], "60"[0], "60"[0], "32"[0], "51"[0], "49"[0], "32"[0], "61"[0], "32"[0], "48"[0], "120"[0], "37"[0], "120"[0], "\xa"[0], "\x0"[0]], c)

    c := (0x80000000 >> 31)
    printf(["48"[0], "120"[0], "56"[0], "48"[0], "48"[0], "48"[0], "48"[0], "48"[0], "48"[0], "48"[0], "32"[0], "62"[0], "62"[0], "32"[0], "51"[0], "49"[0], "32"[0], "61"[0], "32"[0], "48"[0], "120"[0], "37"[0], "120"[0], "\xa"[0], "\x0"[0]], c)

    return 0
}

