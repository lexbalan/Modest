// examples/arr_param/main.cm

@attribute("c-no-print")
import "libc/stdio.hm"


func swap (x: [2]Int32) -> [2]Int32 {
    var out: [2]Int32
    out[0] = x[1]
    out[1] = x[0]
    return out
}

func main () -> Int {
    var a: [2]Int32
    a[0] = 10
    a[1] = 20

    let b = swap(a)

    printf("b[0] = %i\n", b[0])
    printf("b[1] = %i\n", b[1])

    printf("hello world!\n")
    return 0
}

