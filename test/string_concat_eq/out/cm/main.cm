// examples/1.hello_world/main.cm
import "libc/stdio.h"

const hello = "Hello"
const world = "World"
const party_corn = "🎉"

const greeting = hello + " " + world//+ " " + party_corn


const test = "test"


func main () -> Int {
    printf(["%"[0], "s"[0], "\xa"[0], "\x0"[0]], greeting)

    if test == "test" {
        printf(["t"[0], "e"[0], "s"[0], "t"[0], " "[0], "o"[0], "k"[0], "."[0], "\xa"[0], "\x0"[0]])
    } else {
        printf(["t"[0], "e"[0], "s"[0], "t"[0], " "[0], "f"[0], "a"[0], "i"[0], "l"[0], "e"[0], "d"[0], "."[0], "\xa"[0], "\x0"[0]])
    }

    return 0
}

