// examples/1.hello_world/main.cm
import "libc/stdio.h"

const hello = "Hello"
const world = "World"
const party_corn = "\x1f389"

const greeting = hello + " " + world//+ " " + party_corn


const test = "test"


func main () -> Int {
    printf("%s\n", greeting)

    if test == "test" {
        printf("test ok.\n")
    } else {
        printf("test failed.\n")
    }

    return 0
}

