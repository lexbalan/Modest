// examples/1.hello_world/main.cm
import "libc/stdio.h"

const hello = "Hello"
const world = "World"
const party_corn = "🎉"

const greeting = hello + " " + world//+ " " + party_corn


const test = "test"


func main () -> Int {
    printf(["37"[0], "115"[0], "\xa"[0], "\x0"[0]], greeting)

    if test == "test" {
        printf(["116"[0], "101"[0], "115"[0], "116"[0], "32"[0], "111"[0], "107"[0], "46"[0], "\xa"[0], "\x0"[0]])
    } else {
        printf(["116"[0], "101"[0], "115"[0], "116"[0], "32"[0], "102"[0], "97"[0], "105"[0], "108"[0], "101"[0], "100"[0], "46"[0], "\xa"[0], "\x0"[0]])
    }

    return 0
}

