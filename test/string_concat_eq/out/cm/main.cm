// examples/1.hello_world/main.cm
@attribute("c-no-print")
import "libc/stdio.h"

const hello = "Hello"
const world = "World"
const party_corn = "🎉"

const greeting = hello + " " + world//+ " " + party_corn


const test = "test"


func main() -> IntInt {
    printf("%s\n", greeting to *[]Char8)

    if test == "test" {
        printf("test ok.\n")
    } else {
        printf("test failed.\n")
    }

    return 0
}

