// examples/1.hello_world/main.cm

import "libc/stdio"

const hello = "Hello"
const world = "World"
const party_corn = "🎉"

const greeting = hello + " " + world //+ " " + party_corn


const test = "test"


func main() -> Int {
    printf("%s\n", greeting to *Str8)

    if test == "test" {
        printf("test ok.\n")
    } else {
        printf("test failed.\n")
    }

    return 0
}

