type Int Nat32

type Data Int

type Node record {
	next: *Node
	data: *Data
}
let arrSize = 10
type Arr [arrSize]Int
let printf = &printf
var x: Int
let default = 5
func main() -> Int {
	printf("test\n")

	printf("sub::name = '%s'\n", *Str8 name)
	//printf("sub2Name = '%s'\n", *Str8 sub2Name)

	var y: Int32 = default

	let a = 10
	let b = 20
	let s = mid(a, b)
	printf("s = %d\n", s)

	var xx: Int

	//var arr = getArr()
	//arrayShow(&arr, 10)

	x = 12

	return 0
}
func arrayShow(array: *Arr, size: Int) -> Unit {
	printf("arrayShow:\n")
	var i: Int32 = 0
	while i < 10 {
		printf("array[%d] = %d\n", i, array[i])
		i = i + 1
	}
}
func mid(a: Int, b: Int) -> Int {
	let sum = a + b
	return div(sum, 2)
}
func div(a: Int, b: Int) -> Int {
	return a / b
}

