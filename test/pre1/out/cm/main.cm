func arrshow(array: *Arr, size: Int) -> Unit {
	printf("arrayShow:\n")
	var i: Int32 = 0
	while i < 10 {
		printf("array[%d] = %d\n", i, array[i])
		i = i + 1
	}
}

func div(a: Int, b: Int) -> Int {
	return a / b
}

