import "libc/stdio.h"



func main () -> Int {
    printf(["t"[0], "e"[0], "s"[0], "t"[0], " "[0], "c"[0], "a"[0], "s"[0], "t"[0], " "[0], "o"[0], "p"[0], "e"[0], "r"[0], "a"[0], "t"[0], "i"[0], "o"[0], "n"[0], "\xa"[0], "\x0"[0]])

    let x0 = (-1)
    let x1 = (-1)

    let y0 = x0 to Nat64
    let y1 = x1 to Nat64

    printf(["x"[0], "0"[0], " "[0], "="[0], " "[0], "%"[0], "l"[0], "l"[0], "x"[0], "\xa"[0], "\x0"[0]], y0)
    printf(["x"[0], "1"[0], " "[0], "="[0], " "[0], "%"[0], "l"[0], "l"[0], "x"[0], "\xa"[0], "\x0"[0]], y1)


    return 0
}

