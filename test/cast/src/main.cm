// test/cast/main.cm

@attribute("c-no-print")
import "libc/stdio.hm"



func main () -> Int {
    printf("test cast operation\n")

    let x0 = -1 to Int32
    let x1 = -1 to Int64

    let y0 = x0 to Nat64
    let y1 = x1 to Nat64

    printf("x0 = %llx\n", y0)
    printf("x1 = %llx\n", y1)


    return 0
}

