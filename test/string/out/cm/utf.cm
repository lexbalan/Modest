// algorithms from wikipedia
// (https://ru.wikipedia.org/wiki/UTF-16)

import "libc/stdio"
import "./utf"


// декодирует символ UTF-32 в последовательность UTF-8
func utf32_to_utf8(c: Char32, buf: *[4]Char8) -> Nat8 {
	let x = Nat32 c

	if x <= Nat32 0x0000007F {
		buf[Int32 0] = Char8 x
		return Nat8 1

	} else if x <= Nat32 0x000007FF {
		let c0 = x >> 6 and Nat32 0x1F
		let c1 = x >> 0 and Nat32 0x3F
		buf[Int32 0] = Char8 (Nat32 0xC0 or c0)
		buf[Int32 1] = Char8 (Nat32 0x80 or c1)
		return Nat8 2

	} else if x <= Nat32 0x0000FFFF {
		let c0 = x >> 12 and Nat32 0x0F
		let c1 = x >> 06 and Nat32 0x3F
		let c2 = x >> 00 and Nat32 0x3F
		buf[Int32 0] = Char8 (Nat32 0xE0 or c0)
		buf[Int32 1] = Char8 (Nat32 0x80 or c1)
		buf[Int32 2] = Char8 (Nat32 0x80 or c2)
		return Nat8 3

	} else if x <= Nat32 0x0010FFFF {
		let c0 = x >> 18 and Nat32 0x07
		let c1 = x >> 12 and Nat32 0x3F
		let c2 = x >> 06 and Nat32 0x3F
		let c3 = x >> 00 and Nat32 0x3F
		buf[Int32 0] = Char8 (Nat32 0xF0 or c0)
		buf[Int32 1] = Char8 (Nat32 0x80 or c1)
		buf[Int32 2] = Char8 (Nat32 0x80 or c2)
		buf[Int32 3] = Char8 (Nat32 0x80 or c3)
		return Nat8 4
	}

	return Nat8 0
}


// returns n-symbols from input stream
func utf16_to_utf32(c: *[]Char16, result: *Char32) -> Nat8 {
	let leading = Nat32 c[Int32 0]

	if leading < Nat32 0xD800 or leading > Nat32 0xDFFF {
		*result = Char32 leading
		return Nat8 1
	} else if leading >= Nat32 0xDC00 {
		//error("Недопустимая кодовая последовательность.")
	} else {
		var code: Nat32
		code = (leading and Nat32 0x3FF) << 10
		let trailing = Nat32 c[Int32 1]
		if trailing < Nat32 0xDC00 or trailing > Nat32 0xDFFF {
			//error("Недопустимая кодовая последовательность.")
		} else {
			code = code or trailing and Nat32 0x3FF
			*result = Char32 (code + Nat32 0x10000)
			return Nat8 2
		}
	}

	return Nat8 0
}


//
// putchar
//


func utf8_putchar(c: Char8) -> Unit {
	putchar(Int32 c)
}


func utf16_putchar(c: Char16) -> Unit {
	var cc: [2]Char16
	cc[Int32 0] = c
	cc[Int32 1] = Char16 0
	var char32: Char32
	let n = utf16_to_utf32(&cc, &char32)
	utf32_putchar(char32)
}


func utf32_putchar(c: Char32) -> Unit {
	var decoded_buf: [4]Char8
	let n = Int utf32_to_utf8(c, &decoded_buf)

	var i: Int32 = Int32 0
	while i < n {
		let c = decoded_buf[i]
		utf8_putchar(c)
		i = i + Int32 1
	}
}


//
// puts
//

func utf8_puts(s: *Str8) -> Unit {
	var i: Int32 = Int32 0
	while true {
		let c = s[i]
		if c == Char8 0 {break}
		utf8_putchar(c)
		i = i + Int32 1
	}
}


func utf16_puts(s: *Str16) -> Unit {
	var i: Int32 = Int32 0
	while true {
		// нельзя просто так взять и вызвать utf16_putchar
		// тк в строке может быть суррогатная пара UTF_16 символов

		let cc16 = s[i]
		if cc16 == Char16 0 {break}

		var char32: Char32
		let n = utf16_to_utf32(*[]Char16 &s[i], &char32)
		if n == Nat8 0 {break}

		utf32_putchar(char32)

		i = i + Int32 n
	}
}


func utf32_puts(s: *Str32) -> Unit {
	var i: Int32 = Int32 0
	while true {
		let c = s[i]
		if c == Char32 0 {break}
		utf32_putchar(c)
		i = i + Int32 1
	}
}

