// test/9.big_numbers/main.cm
import "libc/stdio.h"



var big0 : Nat128 := 0x0123456789ABCDEFFEDCBA9876543210



func high_128 (x : Nat128) -> Nat64 {
    return x >> 64 to Nat64
}


func low_128 (x : Nat128) -> Nat64 {
    return x and 0xFFFFFFFFFFFFFFFF to Nat64
}


func main () -> Int {

    let big1 = 0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF

    var big2 : Nat128
    big2 := big1

    var big3 : Nat128 := 0x1

    var a : Nat32 := 0x1

    var big_sum : Nat128 := big1 + big2 + a to Nat128

    printf(["98"[0], "105"[0], "103"[0], "48"[0], "32"[0], "61"[0], "32"[0], "48"[0], "120"[0], "37"[0], "108"[0], "108"[0], "88"[0], "37"[0], "108"[0], "108"[0], "88"[0], "\xa"[0], "\x0"[0]], high_128(big0), low_128(big0))
    printf(["98"[0], "105"[0], "103"[0], "49"[0], "32"[0], "61"[0], "32"[0], "48"[0], "120"[0], "37"[0], "108"[0], "108"[0], "88"[0], "37"[0], "108"[0], "108"[0], "88"[0], "\xa"[0], "\x0"[0]], high_128(big1), low_128(big1))
    printf(["98"[0], "105"[0], "103"[0], "50"[0], "32"[0], "61"[0], "32"[0], "48"[0], "120"[0], "37"[0], "108"[0], "108"[0], "88"[0], "37"[0], "108"[0], "108"[0], "88"[0], "\xa"[0], "\x0"[0]], high_128(big2), low_128(big2))
    printf(["98"[0], "105"[0], "103"[0], "51"[0], "32"[0], "61"[0], "32"[0], "48"[0], "120"[0], "37"[0], "108"[0], "108"[0], "88"[0], "37"[0], "108"[0], "108"[0], "88"[0], "\xa"[0], "\x0"[0]], high_128(big3), low_128(big3))
    printf(["98"[0], "105"[0], "103"[0], "95"[0], "115"[0], "117"[0], "109"[0], "32"[0], "61"[0], "32"[0], "48"[0], "120"[0], "37"[0], "108"[0], "108"[0], "88"[0], "37"[0], "108"[0], "108"[0], "88"[0], "\xa"[0], "\x0"[0]], high_128(big_sum), low_128(big_sum))


    // signed big int test
    let sig0 = -1

    var sig1 : Int128 := sig0

    sig1 := sig1 + 1

    printf(["115"[0], "105"[0], "103"[0], "49"[0], "32"[0], "61"[0], "32"[0], "37"[0], "108"[0], "108"[0], "100"[0], "\xa"[0], "\x0"[0]], sig1 to Nat64)

    return 0
}

