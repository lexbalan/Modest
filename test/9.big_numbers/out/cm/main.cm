// test/9.big_numbers/main.cm
import "libc/stdio.h"



var big0 : Nat128 := 0x0123456789ABCDEFFEDCBA9876543210



func high_128 (x : Nat128) -> Nat64 {
    return x >> 64 to Nat64
}


func low_128 (x : Nat128) -> Nat64 {
    return x and 0xFFFFFFFFFFFFFFFF to Nat64
}


func main () -> Int {

    let big1 = 0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF

    var big2 : Nat128
    big2 := big1

    var big3 : Nat128 := 0x1

    var a : Nat32 := 0x1

    var big_sum : Nat128 := big1 + big2 + a to Nat128

    printf(["b"[0], "i"[0], "g"[0], "0"[0], " "[0], "="[0], " "[0], "0"[0], "x"[0], "%"[0], "l"[0], "l"[0], "X"[0], "%"[0], "l"[0], "l"[0], "X"[0], "\xa"[0], "\x0"[0]], high_128(big0), low_128(big0))
    printf(["b"[0], "i"[0], "g"[0], "1"[0], " "[0], "="[0], " "[0], "0"[0], "x"[0], "%"[0], "l"[0], "l"[0], "X"[0], "%"[0], "l"[0], "l"[0], "X"[0], "\xa"[0], "\x0"[0]], high_128(big1), low_128(big1))
    printf(["b"[0], "i"[0], "g"[0], "2"[0], " "[0], "="[0], " "[0], "0"[0], "x"[0], "%"[0], "l"[0], "l"[0], "X"[0], "%"[0], "l"[0], "l"[0], "X"[0], "\xa"[0], "\x0"[0]], high_128(big2), low_128(big2))
    printf(["b"[0], "i"[0], "g"[0], "3"[0], " "[0], "="[0], " "[0], "0"[0], "x"[0], "%"[0], "l"[0], "l"[0], "X"[0], "%"[0], "l"[0], "l"[0], "X"[0], "\xa"[0], "\x0"[0]], high_128(big3), low_128(big3))
    printf(["b"[0], "i"[0], "g"[0], "_"[0], "s"[0], "u"[0], "m"[0], " "[0], "="[0], " "[0], "0"[0], "x"[0], "%"[0], "l"[0], "l"[0], "X"[0], "%"[0], "l"[0], "l"[0], "X"[0], "\xa"[0], "\x0"[0]], high_128(big_sum), low_128(big_sum))


    // signed big int test
    let sig0 = -1

    var sig1 : Int128 := sig0

    sig1 := sig1 + 1

    printf(["s"[0], "i"[0], "g"[0], "1"[0], " "[0], "="[0], " "[0], "%"[0], "l"[0], "l"[0], "d"[0], "\xa"[0], "\x0"[0]], sig1 to Nat64)

    return 0
}

