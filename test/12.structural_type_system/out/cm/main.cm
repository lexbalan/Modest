// test/12.structural_type_system/main.cm
import "libc/stdio.h"

type Type1 record {
    x : Int32
}

type Type2 record {
    x : Int32
}


type Type3 record {
    x : Int32
}


func f0_val (x : Type1) -> Unit {
    printf(["102"[0], "48"[0], "32"[0], "120"[0], "46"[0], "120"[0], "32"[0], "61"[0], "32"[0], "37"[0], "100"[0], "\xa"[0], "\x0"[0]], x.x)
}

func f1_val (x : Type2) -> Unit {
    printf(["102"[0], "49"[0], "32"[0], "120"[0], "46"[0], "120"[0], "32"[0], "61"[0], "32"[0], "37"[0], "100"[0], "\xa"[0], "\x0"[0]], x.x)
}

func f2_val (x : Type3) -> Unit {
    printf(["102"[0], "50"[0], "32"[0], "120"[0], "46"[0], "120"[0], "32"[0], "61"[0], "32"[0], "37"[0], "100"[0], "\xa"[0], "\x0"[0]], x.x)
}

func f3_val (x : record {    x : Int32
}) -> Unit {
    printf(["102"[0], "51"[0], "32"[0], "120"[0], "46"[0], "120"[0], "32"[0], "61"[0], "32"[0], "37"[0], "100"[0], "\xa"[0], "\x0"[0]], x.x)
}


func f0_ptr (x : *Type1) -> Unit {
    printf(["102"[0], "48"[0], "112"[0], "32"[0], "120"[0], "46"[0], "120"[0], "32"[0], "61"[0], "32"[0], "37"[0], "100"[0], "\xa"[0], "\x0"[0]], x.x)
}

func f1_ptr (x : *Type2) -> Unit {
    printf(["102"[0], "49"[0], "112"[0], "32"[0], "120"[0], "46"[0], "120"[0], "32"[0], "61"[0], "32"[0], "37"[0], "100"[0], "\xa"[0], "\x0"[0]], x.x)
}

func f2_ptr (x : *Type3) -> Unit {
    printf(["102"[0], "50"[0], "112"[0], "32"[0], "120"[0], "46"[0], "120"[0], "32"[0], "61"[0], "32"[0], "37"[0], "100"[0], "\xa"[0], "\x0"[0]], x.x)
}

func f3_ptr (x : *record {    x : Int32
}) -> Unit {
    printf(["102"[0], "51"[0], "112"[0], "32"[0], "120"[0], "46"[0], "120"[0], "32"[0], "61"[0], "32"[0], "37"[0], "100"[0], "\xa"[0], "\x0"[0]], x.x)
}


var a : Type1 := {x = 1}
var b : Type2 := {x = 2}
var c : Type3 := {x = 3}



func test_by_value () -> Unit {
    f0_val(a)
    f1_val(a to Type2)
    f2_val(a to Type3)
    //f3_val(a)

    f0_val(b to Type1)
    f1_val(b)
    f2_val(b to Type3)
    //f3_val(b)

    f0_val(c to Type1)
    f1_val(c to Type2)
    f2_val(c)
    //f3_val(c)
}


func test_by_pointer () -> Unit {
    f0_ptr(&a to *Type1)
    f1_ptr(&a to *Type2)
    f2_ptr(&a to *Type3)
    //f3_ptr(&a)

    f0_ptr(&b to *Type1)
    f1_ptr(&b to *Type2)
    f2_ptr(&b to *Type3)
    //f3_ptr(&b)

    f0_ptr(&c to *Type1)
    f1_ptr(&c to *Type2)
    f2_ptr(&c to *Type3)
    //f3_ptr(&c)
}


func main () -> Int {
    test_by_value()
    test_by_pointer()
    return 0
}

