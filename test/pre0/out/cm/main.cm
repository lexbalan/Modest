
import "lib"
@c_include "stdio.h"
type Point record {
	x: Int32
	y: Int32
}
func main() -> Int {
	let a = 10
	let b = 20
	let s = lib.mid(a, b)
	printf("s = %d\n", s)

	// access to private value
	//let x = lib.div(a, b)

	var p: Point = Point {x = 10, y = 20}
	lib.printPoint(p)

	return 0
}
func printf(s: *Str8) -> Unit

