// test/10.const/main.cm
import "libc/math.h"
import "libc/stdio.h"
import "libc/libc.h"
import "misc/minmax.h"



type Point record {
    x : Float64
    y : Float64
}

type Line record {
    a : Point
    b : Point
}

const zero = 0
const pointZero = {x = zero, y = zero}
const pointOne = {x = 1.0, y = 1.0}

const line0 = {
    a = pointZero
    b = pointOne
}

const carr = [0, 10, 15, 20, 25]

const line1 = {
    a = {x = (carr[1]), y = (carr[2])}
    b = {x = (carr[3]), y = (carr[4])}
}

const lines = [line0, line1]


// Pythagorean theorem
func distance (a : Point, b : Point) -> Float {
    let dx = max_float64(a.x, b.x) - min_float64(a.x, b.x)
    let dy = max_float64(a.y, b.y) - min_float64(a.y, b.y)
    let dx2 = pow(dx, 2)
    let dy2 = pow(dy, 2)
    return sqrt(dx2 + dy2)
}


func lineLength (line : Line) -> Float {
    return distance(line.a, line.b)
}


func main () -> Int {
    let lines_0_len = lineLength(lines[0])
    let lines_1_len = lineLength(lines[1])

    printf(["l"[0], "i"[0], "n"[0], "e"[0], "s"[0], "_"[0], "0"[0], "_"[0], "l"[0], "e"[0], "n"[0], " "[0], "="[0], " "[0], "%"[0], "f"[0], "\xa"[0], "\x0"[0]], lines_0_len)
    printf(["l"[0], "i"[0], "n"[0], "e"[0], "s"[0], "_"[0], "1"[0], "_"[0], "l"[0], "e"[0], "n"[0], " "[0], "="[0], " "[0], "%"[0], "f"[0], "\xa"[0], "\x0"[0]], lines_1_len)

    return 0
}

