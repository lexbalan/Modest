// test/10.const/main.cm
@attribute("c-no-print")
import "libc/math.h"
@attribute("c-no-print")
import "libc/stdio.h"
@attribute("c-no-print")
import "libc/libc.h"
@attribute("c-no-print")
import "misc/minmax.h"
@c_include "./minmax.h"


type Point record {
    x: Float64
    y: Float64
}

type Line record {
    a: Pointrecord {
        x: Float64
        y: Float64
    }
    b: Pointrecord {
        x: Float64
        y: Float64
    }
}

const zero = 0
const pointZero = {x = zero, y = zero}
const pointOne = {x = 1.0, y = 1.0}

const line0 = {
    a = pointZero
    b = pointOne
}

const carr = [0, 10, 15] + [20, 25, 30]

const line1 = {
    a = {x = (carr[1]), y = (carr[2])}
    b = {x = (carr[3]), y = (carr[4])}
}

const lines = [line0, line1]


// Pythagorean theorem
func distance(a: Pointrecord {
    x: Float64
    y: Float64
}, b: Pointrecord {
    x: Float64
    y: Float64
}) -> Float<type:{'isa': 'type', 'kind': 'float', 'id': {'isa': 'id', 'str': 'Float', 'ti': {'isa': 'ti', 'file': '/Users/alexbalan/p/Modest/lib/libc/ctypes64.hm', 'line': 59, 'len': 5, 'pos': 5}}, 'generic': False, 'width': 64, 'size': 8, 'align': 8, 'declaration': None, 'definition': {'isa': 'def_type', 'id': {'isa': 'id', 'str': 'Float', 'ti': {'isa': 'ti', 'file': '/Users/alexbalan/p/Modest/lib/libc/ctypes64.hm', 'line': 59, 'len': 5, 'pos': 5}}, 'newtype': {...}, 'type': {'isa': 'type', 'kind': 'float', 'id': {'isa': 'id', 'str': 'Float64', 'ti': None}, 'generic': False, 'width': 64, 'size': 8, 'align': 8, 'c_alias': 'double', 'declaration': None, 'definition': None, 'ops': ['cast', 'eq', 'ne', 'lt', 'gt', 'le', 'ge', 'add', 'sub', 'mul', 'div', 'rem', 'minus'], 'att': [], 'ti': None, 'llvm_alias': 'double'}, 'afterdef': False, 'att': [], 'ti': {'isa': 'ti', 'file': '/Users/alexbalan/p/Modest/lib/libc/ctypes64.hm', 'line': 59, 'len': 4, 'pos': 0}, 'c_alias': 'float', 'nl': 3}, 'ops': ['cast', 'eq', 'ne', 'lt', 'gt', 'le', 'ge', 'add', 'sub', 'mul', 'div', 'rem', 'minus'], 'att': [], 'ti': {'isa': 'ti', 'file': '/Users/alexbalan/p/Modest/lib/libc/ctypes64.hm', 'line': 59, 'len': 5, 'pos': 5}, 'llvm_alias': 'double', 'aliasof': {'isa': 'type', 'kind': 'float', 'id': {'isa': 'id', 'str': 'Float64', 'ti': None}, 'generic': False, 'width': 64, 'size': 8, 'align': 8, 'c_alias': 'double', 'declaration': None, 'definition': None, 'ops': ['cast', 'eq', 'ne', 'lt', 'gt', 'le', 'ge', 'add', 'sub', 'mul', 'div', 'rem', 'minus'], 'att': [], 'ti': None, 'llvm_alias': 'double'}}> {
    let dx = max_float64(a.x, b.x) - min_float64(a.x, b.x)
    let dy = max_float64(a.y, b.y) - min_float64(a.y, b.y)
    let dx2 = pow(dx, 2)
    let dy2 = pow(dy, 2)
    return sqrt(dx2 + dy2)
}


func lineLength(line: Linerecord {
    a: Pointrecord {
        x: Float64
        y: Float64
    }
    b: Pointrecord {
        x: Float64
        y: Float64
    }
}) -> Float<type:{'isa': 'type', 'kind': 'float', 'id': {'isa': 'id', 'str': 'Float', 'ti': {'isa': 'ti', 'file': '/Users/alexbalan/p/Modest/lib/libc/ctypes64.hm', 'line': 59, 'len': 5, 'pos': 5}}, 'generic': False, 'width': 64, 'size': 8, 'align': 8, 'declaration': None, 'definition': {'isa': 'def_type', 'id': {'isa': 'id', 'str': 'Float', 'ti': {'isa': 'ti', 'file': '/Users/alexbalan/p/Modest/lib/libc/ctypes64.hm', 'line': 59, 'len': 5, 'pos': 5}}, 'newtype': {...}, 'type': {'isa': 'type', 'kind': 'float', 'id': {'isa': 'id', 'str': 'Float64', 'ti': None}, 'generic': False, 'width': 64, 'size': 8, 'align': 8, 'c_alias': 'double', 'declaration': None, 'definition': None, 'ops': ['cast', 'eq', 'ne', 'lt', 'gt', 'le', 'ge', 'add', 'sub', 'mul', 'div', 'rem', 'minus'], 'att': [], 'ti': None, 'llvm_alias': 'double'}, 'afterdef': False, 'att': [], 'ti': {'isa': 'ti', 'file': '/Users/alexbalan/p/Modest/lib/libc/ctypes64.hm', 'line': 59, 'len': 4, 'pos': 0}, 'c_alias': 'float', 'nl': 3}, 'ops': ['cast', 'eq', 'ne', 'lt', 'gt', 'le', 'ge', 'add', 'sub', 'mul', 'div', 'rem', 'minus'], 'att': [], 'ti': {'isa': 'ti', 'file': '/Users/alexbalan/p/Modest/lib/libc/ctypes64.hm', 'line': 59, 'len': 5, 'pos': 5}, 'llvm_alias': 'double', 'aliasof': {'isa': 'type', 'kind': 'float', 'id': {'isa': 'id', 'str': 'Float64', 'ti': None}, 'generic': False, 'width': 64, 'size': 8, 'align': 8, 'c_alias': 'double', 'declaration': None, 'definition': None, 'ops': ['cast', 'eq', 'ne', 'lt', 'gt', 'le', 'ge', 'add', 'sub', 'mul', 'div', 'rem', 'minus'], 'att': [], 'ti': None, 'llvm_alias': 'double'}}> {
    return distance(line.a, line.b)
}


func main() -> IntInt {
    let lines_0_len = lineLength(lines[0])
    let lines_1_len = lineLength(lines[1])

    printf("lines_0_len = %f\n", lines_0_len)
    printf("lines_1_len = %f\n", lines_1_len)

    return 0
}

