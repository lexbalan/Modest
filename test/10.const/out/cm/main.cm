// test/10.const/src/main.cm

import "libc/stdio"
import "libc/libc"
import "libc/math"
@attribute("c-no-print")
import "misc/minmax"
@c_include "./minmax.h"


type Point record {
	x: Float64
	y: Float64
}

type Line record {
	a: Point
	b: Point
}

const zero = 0
const pointZero = {x = zero, y = zero}
const pointOne = {x = 1.0, y = 1.0}

const line0 = {
	a = pointZero
	b = pointOne
}

const carr = [0, 10, 15] + [20, 25, 30]

const line1 = {
	a = {x = 10, y = 20}
	b = {x = 30, y = 40}
}


const line2 = {
	a = pointZero
	b = pointOne
}

const line3 = {
	a = {x = 10, y = 20}
	b = {x = 30, y = 40}
}

const lines = [line0, line1, line2, line3]


// Pythagorean theorem
func distance(a: Point, b: Point) -> Float {
	let dx = max_float64(a.x, b.x) - min_float64(a.x, b.x)
	let dy = max_float64(a.y, b.y) - min_float64(a.y, b.y)
	let dx2 = pow(dx, 2)
	let dy2 = pow(dy, 2)
	return sqrt(dx2 + dy2)
}


func lineLength(line: Line) -> Float {
	return distance(line.a, line.b)
}


func main() -> Int {
	let lines_0_len = lineLength(lines[0])
	let lines_1_len = lineLength(lines[1])
	let lines_2_len = lineLength(lines[2])
	let lines_3_len = lineLength(lines[3])

	printf("lines_0_len = %f\n", lines_0_len)
	printf("lines_1_len = %f\n", lines_1_len)

	return 0
}

