// test/slices/src/main.cm

import "libc/stdio"

func array_print(pa: *[]Int32, len: Int32) -> Unit {
	var i: Int32 = Int32 0
	while i < len {
		printf("a[%d] = %d\n", i, pa[i])
		i = i + 1
	}
}


func main() -> Int {
	printf("test slices\n")

	//
	// by value
	//

	var a: [10]Int32 = [None 0, None 1, None 2, None 3, None 4, None 5, None 6, None 7, 8, 9]

	let s1 = a[1 .. 2]
	var i: Int32 = Int32 0
	while i < Int32 lengthof(s1) {
		printf("s1[%d] = %d\n", i, s1[i])
		i = i + 1
	}

	//
	// by ptr
	//

	let pa = &a

	let s2 = pa[5 .. 8]
	i = Int32 0
	while i < Int32 lengthof(s2) {
		printf("s2[%d] = %d\n", i, s2[i])
		i = i + 1
	}

	var vs1: [2]Int32 = s1
	var vs2: [4]Int32 = s2

	let ax = 2
	let bx = 5
	a[ax .. bx] = [None 10, None 20, None 30, 40]

	i = Int32 0
	while i < Int32 lengthof(a) {
		printf("a[%d] = %d\n", i, a[i])
		i = i + 1
	}


	printf("--------------------------------------------\n")

	var s: [10]None = [None 10, None 20, None 30, None 40, None 50, None 60, 70, 80, 90, 100]

	s[2 .. 5] = []

	i = Int32 0
	while i < Int32 lengthof(s) {
		printf("s[%d] = %d\n", i, Nat32 s[i])
		i = i + 1
	}

	printf("--------------------------------------------\n")
	printf("test pointer to slice\n")

	//	let p = &s[2:5]

	// не может неявно привести указатель!
	// *[]Int32 & *[4]Generic(Int7)
	// А должен уметь!
	//	array_print(p, 4)



	return Int 0
}

