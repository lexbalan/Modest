// test/stmt_while/main.cm
import "libc/stdio.h"


func main () -> Int {
    printf(["116"[0], "101"[0], "115"[0], "116"[0], "32"[0], "115"[0], "116"[0], "109"[0], "116"[0], "95"[0], "119"[0], "104"[0], "105"[0], "108"[0], "101"[0], "\xa"[0], "\x0"[0]])

    var a : Int32 := 0
    let b = 10

    while a < b {
        printf(["97"[0], "32"[0], "61"[0], "32"[0], "37"[0], "100"[0], "\xa"[0], "\x0"[0]], a)
        a := a + 1
    }

    return 0
}

