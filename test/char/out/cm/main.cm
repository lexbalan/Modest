// examples/1.hello_world/main.cm
import "libc/stdio.h"

const hello = "Hello"
const world = " World!\n"

const hello_world = hello + world


func main () -> Int {
    var ch08 : Char8
    var ch16 : Char16
    var ch32 : Char32

    //ch08 := "🐀"[0]  // error
    //ch16 := "🐀"[0]  // error
    ch32 := "🐀"[0]

    ch08 := "s"[0]
    ch16 := "А"[0]
    ch32 := "Я"[0]

    printf("ch08 == 0x%x (%c)\n", ch08, ch08)
    printf("ch16 == 0x%x (%c)\n", ch16, ch16)
    printf("ch32 == 0x%x (%c)\n", ch32, ch32)

    printf("Hello World!\n")

    return 0
}

