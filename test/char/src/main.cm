// examples/1.hello_world/main.cm

@attribute("c-no-print")
import "libc/stdio.hm"

const hello = "Hello"
const world = " World!\n"

const hello_world = hello + world


func main () -> Int {
    var ch8 : Char8
    var ch16 : Char16
    var ch32 : Char32

    ch8 := "🐀"[0]
    ch16 := "🐀"[0]
    ch32 := "🐀"[0]

    printf("ch8 == %x\n", ch8)
    printf("ch16 == %x\n", ch16)
    printf("ch32 == %x\n", ch32)

    printf(hello_world)
    return 0
}

