// test/arrays/main.cm

@attribute("c-no-print")
import "libc/math.hm"

@attribute("c-no-print")
import "libc/stdio.hm"

@attribute("c-no-print")
import "libc/libc.hm"

@attribute("c-no-print")
import "misc/minmax.hm"
@c_include("./minmax.h")


var globalArray: [3]Int32 := [1, 2, 3]



func f0(x: [10]Char8) {

}



func main() -> Int {

    f0("hi!")  // generic array [4]Char8 will be implicit casted to [10]Char8

    var i := 0
    while i < 3 {
        let a = globalArray[i]
        printf("globalArray[%d] = %d\n", i, a)
        i := i + 1
    }

    printf("------------------------------------\n")

    var localArray: [3]Int32 := [4, 5, 6]

    i := 0
    while i < 3 {
        let a = localArray[i]
        printf("localArray[%d] = %d\n", i, a)
        i := i + 1
    }

    printf("------------------------------------\n")

    var globalArrayPtr: *[]Int32
    globalArrayPtr := &globalArray

    i := 0
    while i < 3 {
        let a = globalArrayPtr[i]
        printf("globalArrayPtr[%d] = %d\n", i, a)
        i := i + 1
    }

    printf("------------------------------------\n")

    var localArrayPtr: *[]Int32
    localArrayPtr := &localArray

    i := 0
    while i < 3 {
        let a = localArrayPtr[i]
        printf("localArrayPtr[%d] = %d\n", i, a)
        i := i + 1
    }

    return 0
}

