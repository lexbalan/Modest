// test/arrays/main.cm

import "libc/stdio.h"
import "libc/libc.h"
import "libc/math.h"
@attribute("c-no-print")
import "misc/minmax.h"
@c_include "./minmax.h"


var globalArray: [3]Int32 = [1, 2, 3]


func f0(x: [10]Char8) -> Unit {
    var local_copy_of_x: [10]Char8 = x
    printf("f0(\"%s\")\n", &local_copy_of_x)
}


func main() -> Int {
    // generic array [4]Char8 will be implicit casted to [10]Char8
    f0("hi!")

    var i: Int32 = 0
    while i < 3 {
        let a = globalArray[i]
        printf("globalArray[%d] = %d\n", i, a)
        i = i + 1
    }

    printf("------------------------------------\n")

    var localArray: [3]Int32 = [4, 5, 6]

    i = 0
    while i < 3 {
        let a = localArray[i]
        printf("localArray[%d] = %d\n", i, a)
        i = i + 1
    }

    printf("------------------------------------\n")

    var globalArrayPtr: *[]Int32
    globalArrayPtr = &globalArray

    i = 0
    while i < 3 {
        let a = globalArrayPtr[i]
        printf("globalArrayPtr[%d] = %d\n", i, a)
        i = i + 1
    }

    printf("------------------------------------\n")

    var localArrayPtr: *[]Int32
    localArrayPtr = &localArray

    i = 0
    while i < 3 {
        let a = localArrayPtr[i]
        printf("localArrayPtr[%d] = %d\n", i, a)
        i = i + 1
    }

    // assign array to array 1
    // (with equal types)
    var a: [3]Int32 = [1, 2, 3]
    printf("a[0] = %i\n", a[0])
    printf("a[1] = %i\n", a[1])
    printf("a[2] = %i\n", a[2])

    // create (and initialize) new variable b
    // (with type [3]Int32)
    // this variable are copy of array a
    var b: [3]Int32 = a
    printf("b[0] = %i\n", b[0])
    printf("b[1] = %i\n", b[1])
    printf("b[2] = %i\n", b[2])

    // check equality between two arrays (by value)
    if a == b {
        printf("a == b\n")
    } else {
        printf("a != b\n")
    }

    // assign array to array 2
    // (with array extending)
    var c: [3]Int32 = [10, 20, 30]
    var d: [6]Int32 = c to [6]Int32
    printf("d[0] = %i\n", d[0])
    printf("d[1] = %i\n", d[1])
    printf("d[2] = %i\n", d[2])
    printf("d[3] = %i\n", d[3])
    printf("d[4] = %i\n", d[4])
    printf("d[5] = %i\n", d[5])

    return 0
}

