// test/arrays/main.cm

import "libc/stdio.h"
import "libc/libc.h"
import "libc/math.h"
@attribute("c-no-print")
import "misc/minmax.h"
@c_include "./minmax.h"


var globalArray: [3]Int32 = [1, 2, 3]


func f0(x: [10]Char8) -> Unit {
    //
}


func main() -> Int {
    f0("hi!\x0\x0\x0\x0\x0\x0\x0")

    var i: Int32 = 0
    while i < 3 {
        let a = globalArray[i]
        printf("globalArray[%d] = %d\n", i, a)
        i = i + 1
    }

    printf("------------------------------------\n")

    var localArray: [3]Int32 = [4, 5, 6]

    i = 0
    while i < 3 {
        let a = localArray[i]
        printf("localArray[%d] = %d\n", i, a)
        i = i + 1
    }

    printf("------------------------------------\n")

    var globalArrayPtr: *[]Int32
    globalArrayPtr = &globalArray

    i = 0
    while i < 3 {
        let a = globalArrayPtr[i]
        printf("globalArrayPtr[%d] = %d\n", i, a)
        i = i + 1
    }

    printf("------------------------------------\n")

    var localArrayPtr: *[]Int32
    localArrayPtr = &localArray

    i = 0
    while i < 3 {
        let a = localArrayPtr[i]
        printf("localArrayPtr[%d] = %d\n", i, a)
        i = i + 1
    }

    // 1. В LLVM нехрен создавать локальные массивы как insertvalue

    // assign array to array 1
    var a: [3]Int32 = [1, 2, 3]
    var b: [3]Int32 = a
    printf("b[0] = %i\n", b[0])
    printf("b[1] = %i\n", b[1])
    printf("b[2] = %i\n", b[2])

    // assign array to array 2
    var c: [3]Int32 = [10, 20, 30]
    var d: [6]Int32 = c to [6]Int32
    printf("d[0] = %i\n", d[0])
    printf("d[1] = %i\n", d[1])
    printf("d[2] = %i\n", d[2])
    printf("d[3] = %i\n", d[3])
    printf("d[4] = %i\n", d[4])
    printf("d[5] = %i\n", d[5])

    return 0
}

