// test/2.func/main.cm

import "libc/stdio.h"


// declare function f0
func f0() -> Unit

// define function f1
func f1() -> Unit {
    printf("f1 was called\n")
}


func sum(a: Int32, b: Int32) -> Int32 {
    return a + b
}


func print_ab(a: Int32, b: Int32) -> Unit {
    printf("print_ab(a=%i, b=%i)\n", a, b)
}


// define function main
func main() -> Int {
    printf("test func\n")
    f0()
    f1()

    // call function with two arguments and return value
    let arg_a = 1 to Int32
    let arg_b = 2 to Int32
    let sum_result = sum(arg_a, arg_b)
    printf("sum(%i, %i) == %i\n", arg_a, arg_b, sum_result)

    print_ab(10, 20)

    return 0
}

// define function f0
func f0() -> Unit {
    printf("f0 was called\n")
}

