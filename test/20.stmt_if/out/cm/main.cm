import "libc/stdio.h"


func main () -> Int {
    printf(["115"[0], "116"[0], "109"[0], "116"[0], "95"[0], "105"[0], "102"[0], "32"[0], "101"[0], "120"[0], "97"[0], "109"[0], "112"[0], "108"[0], "101"[0], "\xa"[0], "\x0"[0]])

    var a : Int32
    var b : Int32

    printf(["101"[0], "110"[0], "116"[0], "101"[0], "114"[0], "32"[0], "97"[0], "58"[0], "32"[0], "\x0"[0]])
    scanf(["37"[0], "100"[0], "\x0"[0]], &a)
    printf(["101"[0], "110"[0], "116"[0], "101"[0], "114"[0], "32"[0], "98"[0], "58"[0], "32"[0], "\x0"[0]])
    scanf(["37"[0], "100"[0], "\x0"[0]], &b)

    if a > b {
        printf(["97"[0], "32"[0], "62"[0], "32"[0], "98"[0], "\xa"[0], "\x0"[0]])
    } else if a < b {
        printf(["97"[0], "32"[0], "60"[0], "32"[0], "98"[0], "\xa"[0], "\x0"[0]])
    } else {
        printf(["97"[0], "32"[0], "61"[0], "61"[0], "32"[0], "98"[0], "\xa"[0], "\x0"[0]])
    }

    return 0
}

